---
import Layout from '../layouts/Layout.astro';
import UiIcon from '../components/UiIcon.astro';

type IconName =
	| 'arrow'
	| 'bar-chart'
	| 'briefcase'
	| 'check'
	| 'chevron'
	| 'cloud'
	| 'database'
	| 'file'
	| 'filter'
	| 'layers'
	| 'lock'
	| 'message'
	| 'phone'
	| 'rocket'
	| 'settings'
	| 'shield'
	| 'spark'
	| 'thumbs-up'
	| 'users'
	| 'workflow';

interface IconItem {
	name: IconName;
	description: string;
	placements: string[];
}

const icons: IconItem[] = [
	{
		name: 'message',
		description: 'Сообщения, входящие обращения.',
		placements: [
			'Bitrix24 / ds-service-icon: «Единый прием заявок» — «Заявки с сайта, почты и мессенджеров собираются в одном месте».',
		],
	},
	{
		name: 'filter',
		description: 'Аудит, фильтр, воронка.',
		placements: [
			'Bitrix24 / ds-service-icon: «Лиды не теряются» — «Ни один лид не теряется и не забывается».',
			'RBS / ds-service-icon: «Предпроектное обследование» — интервью с руководителями, описание текущих процессов, карта внедрения и список настроек.',
		],
	},
	{
		name: 'workflow',
		description: 'Процессы, автоматизация, связанная логика.',
		placements: [
			'Bitrix24 / ds-service-icon: «Единый сценарий работы» — «Менеджеры работают по единому сценарию, а не "кто как привык"».',
			'RBS / ds-service-icon: «Связываем CRM и ERP-логику» — «Соединяем заказы клиентов, номенклатуру, остатки, закупки, производство, отгрузки и документы».',
			'RBS / темная плашка формы: «продажи, склад, производство».',
		],
	},
	{
		name: 'bar-chart',
		description: 'Аналитика, отчеты, KPI.',
		placements: [
			'Bitrix24 / ds-service-icon: «Прозрачная воронка» — «Руководитель видит прозрачную воронку и реальную загрузку команды».',
			'RBS / ds-service-icon: «Отчеты, обучение и поддержка» — отчеты по продажам, складу, сервису и KPI, инструкции, обучение и помощь после запуска.',
		],
	},
	{
		name: 'file',
		description: 'Документы, расчет, техническое задание.',
		placements: [
			'Bitrix24 / ds-service-icon: «Автоматические документы» — «Счета, КП, акты, напоминания и уведомления формируются автоматически».',
			'RBS / ds-service-icon: «Автоматизируем документы» — «Создаем шаблоны КП, договоров, счетов, актов, УПД и писем, чтобы сотрудники не копировали данные вручную».',
			'RBS / таймлайн: «Техническое задание» — «Описываем модули, карточки, поля, документы, интеграции и критерии готовности».',
			'Мобильный CTA: «Расчет».',
		],
	},
	{
		name: 'phone',
		description: 'Телефония, звонок, каналы связи.',
		placements: [
			'Bitrix24 / ds-service-icon: «Связанные каналы» — «Телефония, 1С, сайт, формы, чат-боты и реклама связываются в единую систему».',
			'RBS / ds-service-icon: «Интеграции с каналами» — заявки с сайта и лендингов, телефония, почта, мессенджеры, API и внешние сервисы.',
			'Bitrix24 / форма расчета: «Нужна ли телефония».',
			'Мобильный CTA: «Позвонить».',
		],
	},
	{
		name: 'layers',
		description: 'Интеграции, слои системы, проектирование.',
		placements: [
			'Bitrix24 / ds-service-icon: «Согласования в системе» — «Внутренние согласования и маршруты заявок перестают жить в чатах и таблицах».',
			'Bitrix24 / ds-service-icon: «Интеграции» — 1С, сайт, интернет-магазин, телефония, WhatsApp, Telegram, email и чаты.',
			'RBS / ds-service-icon: «Настраиваем интеграции» — сайт, формы, почта, телефония, мессенджеры, 1С, API и внешние сервисы.',
			'RBS / таймлайн: «Интеграции» — связываем РосБизнесСофт с 1С, сайтом, телефонией, почтой, API и внешними сервисами.',
		],
	},
	{
		name: 'database',
		description: 'Данные, база, миграция, 1С.',
		placements: [
			'Bitrix24 / ds-service-icon: «Чистая клиентская база» — «База клиентов переносится и очищается от дублей».',
			'Bitrix24 / ds-service-icon: «Данные и миграция» — перенос базы клиентов из Excel, миграция из amoCRM, Megaplan и других CRM, очистка дублей.',
			'RBS / ds-service-icon: «Переносим данные» — миграция клиентов, компаний, контактов, товаров, сделок, истории и остатков из Excel, 1С или старой CRM.',
			'RBS / ds-service-icon: «Интеграция с 1С» — контрагенты, товары, счета, заказы, оплаты и остатки.',
		],
	},
	{
		name: 'users',
		description: 'Команда, сотрудники, обучение.',
		placements: [
			'Bitrix24 / ds-service-icon: «Быстрый вход в работу» — «Сотрудники быстрее входят в работу после обучения».',
			'Bitrix24 / тариф: «Отдел продаж под ключ» — управляемый отдел продаж, аудит продаж, воронки, роботы, автоматизация и отчеты.',
			'Bitrix24 / ds-service-icon: «Обучение и сопровождение» — обучение сотрудников, руководителей аналитике, поддержка после запуска.',
			'RBS / ds-service-icon: «Внедряем в ежедневную работу» — обучение команды, инструкции, регламенты, KPI и правила контроля качества заполнения CRM.',
		],
	},
	{
		name: 'briefcase',
		description: 'Продажи, бизнес-контур.',
		placements: [
			'Bitrix24 / ds-service-icon: «CRM и продажи» — воронки продаж, карточки лидов, сделок, компаний и контактов, повторные продажи и KPI менеджеров.',
			'RBS / ds-service-icon: «Наводим порядок в продажах» — «Настраиваем клиентскую базу, сделки, воронки, задачи, напоминания, контроль звонков и писем».',
		],
	},
	{
		name: 'settings',
		description: 'Настройки, конфигурация, доработки.',
		placements: [
			'Bitrix24 / ds-service-icon: «Индивидуальные доработки» — кастомные модули, нестандартные отчеты, API-интеграции, сложные роли доступа, оптимизация портала.',
			'RBS / ds-service-icon: «Настройка CRM и ERP-модулей» — карточки клиентов, сделок, заказов и товаров, склады, документы, проекты, сервисные обращения, производство.',
			'Bitrix24 / таймлайн: «Настройка» — портал, права, CRM, роботы, формы, телефония, почта и нужные сервисы.',
		],
	},
	{
		name: 'rocket',
		description: 'Быстрый старт, запуск.',
		placements: [
			'Bitrix24 / тариф: «Быстрый старт CRM» — «Для малого бизнеса и первого запуска Bitrix24».',
			'Bitrix24 / таймлайн: «Запуск» — перенос данных, проверка сценариев, обучение команды и старт работы в системе.',
			'RBS / тариф: «Первичное внедрение» — быстрый запуск CRM с базовой настройкой для продаж, пользователей, прав и рабочего сценария.',
			'RBS / таймлайн: «Запуск и развитие» — запуск системы, контроль первых результатов и донастройка процессов.',
		],
	},
	{
		name: 'shield',
		description: 'Безопасность, enterprise, коробочная версия.',
		placements: [
			'Bitrix24 / тариф: «Коробка и сложные интеграции» — требования к безопасности, инфраструктуре, кастомизации и интеграциям.',
		],
	},
	{
		name: 'thumbs-up',
		description: 'Выгода, положительный результат.',
		placements: [
			'Bitrix24 / блок «Ваша выгода» — «После внедрения Bitrix24 бизнес получает не еще один сервис, а управляемый процесс».',
			'RBS / блок «Ваша выгода» — единая система для продаж, операций и управленческого контроля.',
			'RBS / блок «После запуска» — «Стало понятно, где сделки», «Документы готовятся быстрее», «Заявки не теряются».',
		],
	},
	{
		name: 'check',
		description: 'Галочка, подтверждение, преимущество.',
		placements: [
			'Bitrix24 / список выгод: меньше потерь лидов, выше скорость обработки заявок, меньше ручной работы, прозрачная отчетность, единая история коммуникаций.',
			'RBS / список выгод: единая база клиентов и сделок, продажи связаны со складом, меньше ручного контроля, документы по шаблонам, понятные KPI и отчеты.',
			'Карточки тарифов и услуг: пункты состава работ и преимуществ.',
		],
	},
	{
		name: 'chevron',
		description: 'Переход, раскрытие, вложенный пункт.',
		placements: [
			'Хлебные крошки: разделитель между «Все услуги» и текущей страницей.',
			'Bitrix24 и RBS / списки услуг: маркер подпунктов внутри карточек.',
			'FAQ: иконка раскрытия вопроса.',
		],
	},
	{
		name: 'arrow',
		description: 'CTA, переход к следующему действию.',
		placements: [
			'Bitrix24: «Получить консультацию», «Собрать состав работ», «Получить расчет».',
			'RBS: «Получить консультацию», «Собрать план внедрения», «Получить план внедрения».',
			'Страница DS: кнопки «Компоненты», «Отправить заявку», переходы к кейсам и секциям.',
		],
	},
	{
		name: 'spark',
		description: 'Акцент, дополнительное направление.',
		placements: [
			'DS / карточки услуг: группа «Дополнительно» — искусственный интеллект и сопровождение IT-проектов.',
		],
	},
	{
		name: 'cloud',
		description: 'Облако.',
		placements: ['Объявлена в UiIcon, но в текущих блоках сайта не размещена.'],
	},
	{
		name: 'lock',
		description: 'Замок, доступ, безопасность.',
		placements: ['Объявлена в UiIcon, но в текущих блоках сайта не размещена.'],
	},
];
---

<Layout
	title="Иконки сайта — IT Time Now"
	description="Список SVG-иконок сайта IT Time Now с описаниями и примерами использования в блоках."
>
	<section class="mx-auto max-w-7xl px-6 py-16 sm:py-24">
		<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Справочник</p>
		<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Иконки сайта</h1>
		<p class="mt-4 max-w-3xl text-lg leading-8 text-neutral-600 dark:text-neutral-400">
			Список иконок из компонента UiIcon и описания из блоков, где эти иконки размещены.
			Основные источники: страницы внедрения Bitrix24 и РосБизнесСофт.
		</p>

		<div class="mt-12 overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-sm dark:border-neutral-800 dark:bg-neutral-950">
			<div class="overflow-x-auto">
				<table class="min-w-[980px] divide-y divide-neutral-200 text-left dark:divide-neutral-800">
					<thead class="bg-neutral-50 text-xs font-semibold uppercase tracking-wider text-neutral-500 dark:bg-neutral-900/70 dark:text-neutral-400">
						<tr>
							<th class="w-24 px-5 py-4">Иконка</th>
							<th class="w-40 px-5 py-4">Название</th>
							<th class="w-72 px-5 py-4">Описание</th>
							<th class="px-5 py-4">Описание из блоков</th>
						</tr>
					</thead>
					<tbody class="divide-y divide-neutral-200 dark:divide-neutral-800">
						{icons.map((item) => (
							<tr class="align-top transition hover:bg-neutral-50/70 dark:hover:bg-neutral-900/50">
								<td class="px-5 py-5">
									<div class="flex h-12 w-12 items-center justify-center rounded-xl border border-neutral-200 bg-neutral-50 text-indigo-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-indigo-400">
										<UiIcon name={item.name} class="h-6 w-6" />
									</div>
								</td>
								<td class="px-5 py-5">
									<code class="rounded-md bg-neutral-100 px-2 py-1 text-sm text-neutral-900 dark:bg-neutral-900 dark:text-neutral-100">
										{item.name}
									</code>
								</td>
								<td class="px-5 py-5 text-sm leading-6 text-neutral-700 dark:text-neutral-300">
									{item.description}
								</td>
								<td class="px-5 py-5">
									<ul class="space-y-3 text-sm leading-6 text-neutral-700 dark:text-neutral-300">
										{item.placements.map((placement) => (
											<li class="border-l-2 border-indigo-200 pl-3 dark:border-indigo-900">
												{placement}
											</li>
										))}
									</ul>
								</td>
							</tr>
						))}
					</tbody>
				</table>
			</div>
		</div>
	</section>
</Layout>
