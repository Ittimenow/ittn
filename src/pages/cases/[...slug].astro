---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
	const cases = await getCollection('cases');
	return cases.map((c) => ({ params: { slug: c.id }, props: { c } }));
}

const { c } = Astro.props;
const { Content } = await render(c);
const pageUrl = new URL(Astro.url.pathname, Astro.site ?? Astro.url).href;
const caseImage = c.data.cover ? new URL(c.data.cover, Astro.site ?? Astro.url).href : undefined;
const caseSchema = {
	'@context': 'https://schema.org',
	'@type': 'CreativeWork',
	name: c.data.title,
	description: c.data.summary,
	url: pageUrl,
	inLanguage: 'ru-RU',
	...(caseImage ? { image: caseImage } : {}),
	...(c.data.year ? { datePublished: String(c.data.year) } : {}),
	about: c.data.services,
	creator: {
		'@type': 'Organization',
		name: 'IT TIME NOW',
	},
};
const breadcrumbSchema = {
	'@context': 'https://schema.org',
	'@type': 'BreadcrumbList',
	itemListElement: [
		{
			'@type': 'ListItem',
			position: 1,
			name: 'Главная',
			item: new URL('/', Astro.site ?? Astro.url).href,
		},
		{
			'@type': 'ListItem',
			position: 2,
			name: 'Кейсы',
			item: new URL('/cases/', Astro.site ?? Astro.url).href,
		},
		{
			'@type': 'ListItem',
			position: 3,
			name: c.data.title,
			item: pageUrl,
		},
	],
};
---

<Layout
	title={`${c.data.title} — ittimenow`}
	description={c.data.summary}
	image={c.data.cover}
	structuredData={[caseSchema, breadcrumbSchema]}
>
	<article class="case-article mx-auto max-w-4xl px-6 py-16">
		<a href="/cases/" class="text-sm text-neutral-500 hover:text-neutral-900 dark:hover:text-neutral-100">
			← все кейсы
		</a>

		<header class="mt-6 pb-8">
			<div class="flex flex-wrap items-center gap-2 text-sm text-neutral-500">
				{c.data.industry && <span>{c.data.industry}</span>}
				{c.data.industry && c.data.year && <span>·</span>}
				{c.data.year && <span>{c.data.year}</span>}
			</div>

			<h1
				class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl"
				transition:name={`case-${c.id}`}
			>
				{c.data.title}
			</h1>

			{c.data.stack.length > 0 && (
				<div class="mt-5 flex flex-wrap gap-1.5">
					{c.data.stack.map((s) => (
						<span class="rounded-full border border-neutral-200 bg-neutral-50 px-2.5 py-1 text-xs text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
							{s}
						</span>
					))}
				</div>
			)}

			{c.data.coverVideo ? (
				<video
					class="case-cover"
					autoplay
					loop
					muted
					playsinline
					preload="auto"
					aria-label={c.data.title}
				>
					<source
						src={c.data.coverVideo}
						type={c.data.coverVideo.endsWith('.webm') ? 'video/webm' : 'video/mp4'}
					/>
				</video>
			) : c.data.cover && (
				<img
					src={c.data.cover}
					alt={c.data.title}
					class="case-cover"
					loading="eager"
					decoding="async"
				/>
			)}
		</header>

		<div
			class:list={['prose-content mt-8', (c.data.cover || c.data.coverVideo) && 'has-cover']}
			data-results-cta={c.data.resultsCta ? 'true' : 'false'}
		>
			<Content />
		</div>
	</article>
</Layout>

<style>
	.prose-content :global(h2) { margin-top: 2rem; margin-bottom: 0.75rem; font-size: 1.5rem; font-weight: 600; }
	.prose-content :global(h3) { margin-top: 1.75rem; margin-bottom: 0.75rem; font-size: 1.375rem; font-weight: 600; }
	.prose-content :global(h4) { margin: 0.875rem 0 0.25rem; font-size: 1.25rem; font-weight: 600; }
	.prose-content :global(p) { margin: 0.75rem 0; line-height: 1.75; color: var(--prose-text); }
	.prose-content :global(ul) { margin: 0.75rem 0; padding-left: 1.5rem; list-style: disc; color: var(--prose-text); }
	.prose-content :global(ol) { margin: 0.75rem 0; padding-left: 1.5rem; list-style: decimal; color: var(--prose-text); }
	.prose-content :global(li + li) { margin-top: 0.25rem; }
	.prose-content :global(a:not(.case-results-button)) {
		color: var(--ds-primary);
		text-decoration: underline;
		text-underline-offset: 4px;
	}
	.prose-content :global(a:not(.case-results-button):hover) {
		color: #1d24d9;
	}
	.case-article {
		--case-image-width: min(960px, calc(100vw - 1.5rem));
		--case-video-width: min(720px, 100%);
	}
	.case-cover,
	.prose-content :global(img) {
		display: block;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 2.5rem calc((100% - var(--case-image-width)) / 2);
		border-radius: 24px;
		box-shadow: var(--ds-shadow);
	}
	video.case-cover {
		background: #000000;
	}
	.prose-content :global(.case-video) {
		display: block;
		background: #000000;
		width: var(--case-video-width);
		max-width: none;
		margin: 1.5rem 0 2.5rem calc((100% - var(--case-video-width)) / 2);
		border-radius: 24px;
		box-shadow: var(--ds-shadow);
		margin-left: calc((100% - var(--case-video-width)) / 2);
	}
	.prose-content :global(.case-portrait-video) {
		width: min(320px, 100%);
		margin: 1.5rem auto 2.5rem;
	}
	.prose-content :global(.case-slider) {
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-slider-viewport) {
		position: relative;
		overflow: hidden;
		border-radius: 24px;
		background: #000000;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.case-slider-track) {
		display: flex;
		transition: transform 420ms ease;
	}
	.prose-content :global(.case-slider-slide) {
		min-width: 100%;
	}
	.prose-content :global(.case-slider-slide img) {
		width: 100%;
		max-width: none;
		margin: 0;
		border-radius: 0;
		box-shadow: none;
	}
	.prose-content :global(.wum-prototype-slider .case-slider-viewport) {
		background: #f4f4f5;
	}
	.prose-content :global(.wum-prototype-slider .case-slider-slide) {
		display: flex;
		aspect-ratio: 4 / 3;
		align-items: center;
		justify-content: center;
	}
	.prose-content :global(.wum-prototype-slider .case-slider-slide img) {
		height: 100%;
		object-fit: contain;
	}
	.prose-content :global(.case-work-list) {
		display: grid;
		grid-template-columns: minmax(180px, 0.85fr) minmax(0, 1.65fr);
		gap: 1.5rem;
		align-items: start;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 2rem calc((100% - var(--case-image-width)) / 2);
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 24px;
		background: var(--ds-card);
		padding: 1.5rem;
		box-shadow: var(--ds-shadow);
		backdrop-filter: blur(40px);
	}
	:global(.dark) .prose-content :global(.case-work-list) {
		border-color: rgba(255, 255, 255, 0.1);
	}
	.prose-content :global(.case-work-list h3) {
		margin: 0;
		font-size: 1.375rem;
		line-height: 1.2;
	}
	.prose-content :global(.case-work-list ol) {
		margin: 0;
		padding-left: 1.25rem;
		list-style: decimal;
		color: var(--prose-text);
	}
	.prose-content :global(.case-work-list li) {
		line-height: 1.65;
	}
	.prose-content :global(.case-work-list li + li) {
		margin-top: 0.375rem;
	}
	.prose-content :global(.case-timeline) {
		position: relative;
		display: grid;
		gap: 0;
		width: min(760px, 100%);
		margin: 2rem auto 3rem;
		padding: 0;
		list-style: none;
		counter-reset: case-timeline;
	}
	.prose-content :global(.case-timeline::before) {
		position: absolute;
		top: 1.5rem;
		bottom: 1.5rem;
		left: 1.5rem;
		width: 2px;
		background: color-mix(in srgb, var(--ds-primary) 34%, transparent);
		content: '';
	}
	.prose-content :global(.case-timeline li) {
		position: relative;
		min-height: 5rem;
		margin: 0;
		padding: 0 0 1.5rem 5rem;
		counter-increment: case-timeline;
	}
	.prose-content :global(.case-timeline li:last-child) {
		padding-bottom: 0;
	}
	.prose-content :global(.case-timeline li::before) {
		position: absolute;
		top: 0;
		left: 0;
		z-index: 1;
		display: flex;
		width: 3rem;
		height: 3rem;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		background: var(--ds-primary);
		color: #ffffff;
		content: counter(case-timeline);
		font-size: 0.875rem;
		font-weight: 700;
		box-shadow: 0 0 0 8px var(--ds-bg);
	}
	.prose-content :global(.case-timeline h4) {
		margin: 0 0 0.25rem;
		color: var(--prose-text);
		font-size: 1.125rem;
		line-height: 1.3;
	}
	.prose-content :global(.case-timeline p) {
		margin: 0;
		line-height: 1.65;
	}
	.prose-content :global(.case-waybills) {
		display: grid;
		gap: 1.5rem;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-waybill-row) {
		display: grid;
		grid-template-columns: minmax(180px, 1fr) minmax(0, 3fr);
		gap: 1.5rem;
		align-items: center;
	}
	.prose-content :global(.case-waybill-row.is-reversed) {
		grid-template-columns: minmax(0, 2fr) minmax(180px, 1fr);
	}
	.prose-content :global(.case-waybill-copy) {
		min-width: 0;
	}
	.prose-content :global(.case-waybill-copy p) {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.7;
	}
	.prose-content :global(.case-waybill-media img),
	.prose-content :global(.case-waybill-video) {
		display: block;
		width: 100%;
		max-width: none;
		margin: 0;
		border-radius: 24px;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.case-waybill-video) {
		background: #000000;
	}
	.prose-content :global(.case-waybill-video-narrow) {
		width: min(320px, 100%);
		justify-self: center;
	}
	.prose-content :global(.case-interface-features) {
		display: grid;
		gap: 1rem;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-interface-feature) {
		display: grid;
		grid-template-columns: minmax(220px, 0.85fr) minmax(0, 1.35fr);
		gap: 1.25rem;
		align-items: center;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 24px;
		background: var(--ds-card);
		padding: 1.25rem;
		box-shadow: var(--ds-shadow);
		backdrop-filter: blur(40px);
	}
	:global(.dark) .prose-content :global(.case-interface-feature) {
		border-color: rgba(255, 255, 255, 0.1);
	}
	.prose-content :global(.case-interface-feature.is-reversed) {
		grid-template-columns: minmax(0, 1.35fr) minmax(220px, 0.85fr);
	}
	.prose-content :global(.case-interface-copy) {
		min-width: 0;
	}
	.prose-content :global(.case-interface-copy h4) {
		margin: 0;
		color: var(--prose-text);
		font-size: 1.25rem;
		line-height: 1.25;
	}
	.prose-content :global(.case-interface-copy p) {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.65;
	}
	.prose-content :global(.case-interface-media) {
		min-width: 0;
	}
	.prose-content :global(.case-interface-media img) {
		width: 100%;
		max-width: none;
		margin: 0;
		border-radius: 16px;
		background: #ffffff;
		box-shadow: none;
	}
	.prose-content :global(.case-interface-media-small) {
		display: flex;
		justify-content: center;
	}
	.prose-content :global(.case-interface-media-small img) {
		width: min(390px, 100%);
		border-radius: 12px;
	}
	.prose-content :global(.case-slider-controls) {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 1rem;
		margin-top: 1rem;
	}
	.prose-content :global(.case-slider-button) {
		display: inline-flex;
		flex: 0 0 45px;
		width: 45px;
		height: 45px;
		align-items: center;
		justify-content: center;
		border: 0;
		background: transparent;
		color: rgba(113, 113, 122, 0.42);
		font-size: 40px;
		font-weight: 300;
		line-height: 1;
		transition: color 180ms ease, transform 180ms ease;
	}
	.prose-content :global(.case-slider-button:hover) {
		color: #232bff;
		transform: scale(1.03);
	}
	.prose-content :global(.case-slider-dots) {
		display: flex;
		align-items: center;
		justify-content: center;
		gap: 0.5rem;
	}
	.prose-content :global(.case-slider-dot) {
		width: 10px;
		height: 10px;
		border: 0;
		border-radius: 9999px;
		background: rgba(113, 113, 122, 0.42);
		padding: 0;
		transition: background 180ms ease, transform 180ms ease, width 180ms ease;
	}
	.prose-content :global(.case-slider-dot.is-active) {
		width: 28px;
		background: var(--ds-primary);
	}
	.prose-content :global(.case-mobile-showcase) {
		display: grid;
		grid-template-columns: minmax(180px, 0.8fr) minmax(0, 1.35fr) minmax(180px, 0.8fr);
		gap: 1.5rem;
		align-items: center;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-mobile-showcase-video),
	.prose-content :global(.case-mobile-showcase img) {
		display: block;
		width: min(280px, 100%);
		max-width: none;
		justify-self: center;
		margin: 0;
		border-radius: 24px;
		background: #000000;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.case-mobile-showcase img) {
		background: transparent;
	}
	.prose-content :global(.case-mobile-showcase-copy) {
		min-width: 0;
	}
	.prose-content :global(.case-mobile-showcase-copy p) {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.7;
	}
	.prose-content :global(.case-mobile-showcase-copy p + p) {
		margin-top: 1rem;
	}
	.prose-content :global(.case-video-copy-row) {
		display: grid;
		grid-template-columns: minmax(0, 1.4fr) minmax(220px, 0.8fr);
		gap: 1.5rem;
		align-items: center;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-video-copy-row video) {
		display: block;
		width: 100%;
		max-width: none;
		margin: 0;
		border-radius: 24px;
		background: #000000;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.case-video-copy-row p) {
		margin: 0;
		font-size: 1.0625rem;
		line-height: 1.7;
	}
	.prose-content :global(.wum-video-grid) {
		display: grid;
		gap: 1rem;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.wum-video-grid-mobile) {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}
	.prose-content :global(.wum-video-grid video) {
		display: block;
		width: 100%;
		border-radius: 20px;
		background: #000000;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.wum-feature-video) {
		width: min(540px, 100%);
		margin-left: auto;
		margin-right: auto;
	}
	.prose-content :global(.case-stage-grid),
	.prose-content :global(.case-media-grid) {
		display: grid;
		grid-template-columns: repeat(2, minmax(0, 1fr));
		gap: 1rem;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-stage-grid) {
		position: relative;
		grid-template-columns: repeat(4, minmax(0, 1fr));
		gap: 1.5rem;
		padding-top: 2.5rem;
		counter-reset: case-stage;
	}
	.prose-content :global(.case-stage-grid::before) {
		position: absolute;
		top: 1rem;
		right: 12.5%;
		left: 12.5%;
		height: 2px;
		background: color-mix(in srgb, var(--ds-primary) 38%, transparent);
		content: '';
	}
	.prose-content :global(.case-media-grid-four) {
		grid-template-columns: repeat(4, minmax(0, 1fr));
	}
	.prose-content :global(.case-stage-grid-six) {
		grid-template-columns: repeat(3, minmax(0, 1fr));
		row-gap: 4rem;
	}
	.prose-content :global(.case-stage-grid-six::before) {
		display: none;
	}
	.prose-content :global(.case-image-gallery),
	.prose-content :global(.case-mobile-image-grid) {
		display: grid;
		gap: 1rem;
		width: var(--case-image-width);
		max-width: none;
		margin: 1.5rem 0 3rem calc((100% - var(--case-image-width)) / 2);
	}
	.prose-content :global(.case-image-gallery-three) {
		grid-template-columns: repeat(3, minmax(0, 1fr));
	}
	.prose-content :global(.case-mobile-image-grid) {
		grid-template-columns: repeat(5, minmax(0, 1fr));
	}
	.prose-content :global(.case-image-gallery img),
	.prose-content :global(.case-mobile-image-grid img) {
		width: 100%;
		max-width: none;
		height: 100%;
		margin: 0;
		border-radius: 18px;
		object-fit: cover;
		box-shadow: var(--ds-shadow);
	}
	.prose-content :global(.case-stage-card),
	.prose-content :global(.case-media-card) {
		min-width: 0;
		margin: 0;
		border: 1px solid rgba(255, 255, 255, 0.78);
		border-radius: 24px;
		background: var(--ds-card);
		padding: 1.5rem;
		box-shadow: var(--ds-shadow);
		backdrop-filter: blur(40px);
	}
	:global(.dark) .prose-content :global(.case-stage-card),
	:global(.dark) .prose-content :global(.case-media-card) {
		border-color: rgba(255, 255, 255, 0.1);
	}
	.prose-content :global(.case-stage-card) {
		position: relative;
		border: 0;
		background: transparent;
		padding: 0;
		box-shadow: none;
		backdrop-filter: none;
		counter-increment: case-stage;
	}
	.prose-content :global(.case-stage-card::before) {
		position: absolute;
		top: -2.5rem;
		left: 50%;
		display: flex;
		width: 2rem;
		height: 2rem;
		align-items: center;
		justify-content: center;
		border-radius: 9999px;
		background: var(--ds-primary);
		color: #ffffff;
		content: counter(case-stage);
		font-size: 0.75rem;
		font-weight: 700;
		transform: translateX(-50%);
		box-shadow: 0 0 0 6px var(--ds-bg);
	}
	.prose-content :global(.case-stage-card h4) {
		margin: 0 0 0.5rem;
		text-align: center;
	}
	.prose-content :global(.case-stage-card p) {
		margin: 0;
		font-size: 0.875rem;
		line-height: 1.55;
		text-align: center;
	}
	.prose-content :global(.case-media-card) {
		display: grid;
		gap: 1rem;
	}
	.prose-content :global(.case-media-card figcaption) {
		font-size: 1rem;
		font-weight: 600;
		line-height: 1.35;
	}
	.prose-content :global(.case-media-card video) {
		display: block;
		width: 100%;
		border-radius: 16px;
		background: #000000;
	}
	.prose-content :global(.case-media-grid-four .case-media-card) {
		border: 0;
		background: transparent;
		padding: 0;
		box-shadow: none;
		backdrop-filter: none;
	}
	.case-cover {
		margin-top: 2rem;
	}
	.prose-content.has-cover :global(h2:first-child + p + p:has(> img:only-child)) {
		display: none;
	}
