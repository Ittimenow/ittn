		border-color: var(--ds-border);
		box-shadow: 0 0 0 3px rgba(113, 113, 122, 0.18);
	}

	.ds-select-form .ds-select-trigger {
		min-height: 48px;
		border-radius: 16px;
		padding: 12px 14px;
