	}

	.ds-nav-pill:hover,
	.ds-page-button:hover,
	.ds-tab.is-active,
	.ds-page-button.is-active {
		border-color: transparent;
		background: rgba(35, 43, 255, 0.09);
		color: var(--ds-primary);
	}

	.ds-btn {
		--ds-btn-fill: var(--ds-primary);
		--ds-btn-hover-color: #ffffff;
		--ds-btn-hover-border: transparent;
		display: inline-flex;
		min-height: 44px;
		position: relative;
		align-items: center;
		justify-content: center;
		gap: 8px;
		overflow: hidden;
		border-radius: 9999px;
		padding: 0 30px;
		border: 1.5px solid transparent;
		font-size: 14px;
		font-weight: 700;
		line-height: 1;
		cursor: pointer;
		isolation: isolate;
		transition:
			border-color 800ms cubic-bezier(0.19, 1, 0.22, 1),
			background 800ms cubic-bezier(0.19, 1, 0.22, 1),
			color 800ms cubic-bezier(0.19, 1, 0.22, 1),
			transform 800ms cubic-bezier(0.19, 1, 0.22, 1);
	}

	.ds-btn::before {
		position: absolute;
		top: 50%;
		left: 50%;
		z-index: 0;
		width: 16px;
		height: 16px;
		border-radius: 9999px;
		background: var(--ds-btn-fill);
		opacity: 0;
		content: "";
		transform: translate(-50%, -50%);
		transition:
			width 800ms cubic-bezier(0.19, 1, 0.22, 1),
			height 800ms cubic-bezier(0.19, 1, 0.22, 1),
			opacity 800ms cubic-bezier(0.19, 1, 0.22, 1);
	}

	.ds-btn::after {
		position: absolute;
		top: 50%;
		left: -28px;
		z-index: 2;
		color: currentColor;
		content: "→";
		font-size: 18px;
		line-height: 1;
		transform: translateY(-50%);
		transition:
			left 800ms cubic-bezier(0.34, 1.56, 0.64, 1),
			color 800ms cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.ds-btn > span,
	:global(.ds-btn > svg) {
		position: relative;
		z-index: 1;
	}

	.ds-btn > span {
		transform: translateX(-4px);
		transition: transform 800ms ease;
	}

	:global(.ds-btn > svg) {
		flex: 0 0 auto;
		transition:
			opacity 800ms cubic-bezier(0.34, 1.56, 0.64, 1),
			transform 800ms cubic-bezier(0.34, 1.56, 0.64, 1);
	}

	.ds-btn:hover {
		border-color: var(--ds-btn-hover-border);
		color: var(--ds-btn-hover-color);
	}

	.ds-btn:hover::before {
		width: 340px;
		height: 340px;
		opacity: 1;
	}

	.ds-btn:hover::after {
		left: 16px;
		color: var(--ds-btn-hover-color);
	}

	.ds-btn:hover > span {
		transform: translateX(10px);
	}

	:global(.ds-btn:hover > svg:last-child) {
		opacity: 0;
		transform: translateX(64px);
	}

	.ds-btn:active {
		transform: scale(0.96);
	}

