	.ds-input {
		width: 100%;
		min-height: 48px;
		border-radius: 16px;
		border: 1px solid #e4e4e7;
		background: #ffffff;
		padding: 12px 14px;
		color: #18181b;
		font-size: 14px;
		outline: none;
		transition: border-color 150ms ease, box-shadow 150ms ease;
