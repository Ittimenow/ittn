<script>
	function bindDs2Faq() {
		document.querySelectorAll<HTMLDetailsElement>('.ds-faq').forEach((details) => {
			if (details.dataset.faqBound) return;
			details.dataset.faqBound = '1';

			const summary = details.querySelector('summary');
			const content = details.querySelector<HTMLElement>('.ds-faq-content');
			if (!summary || !content) return;

			summary.addEventListener('click', (event) => {
				event.preventDefault();

				if (details.dataset.animating === '1') return;
				details.dataset.animating = '1';

				const duration = 220;
				const easing = 'ease-out';

				if (details.open) {
					const startHeight = `${content.offsetHeight}px`;
					details.classList.add('is-closing');
					content.style.height = startHeight;
					content.style.overflow = 'hidden';

					const animation = content.animate(
						[
							{ height: startHeight, opacity: 1, transform: 'translateY(0)' },
							{ height: '0px', opacity: 0, transform: 'translateY(-4px)' },
						],
						{ duration, easing: 'ease-in' },
					);

					animation.onfinish = () => {
						details.open = false;
						details.classList.remove('is-closing');
						content.style.height = '';
						content.style.overflow = '';
						delete details.dataset.animating;
					};
					animation.oncancel = () => {
						details.classList.remove('is-closing');
						content.style.height = '';
						content.style.overflow = '';
						delete details.dataset.animating;
					};
					return;
				}

				details.open = true;
				const endHeight = `${content.offsetHeight}px`;
				content.style.height = '0px';
				content.style.overflow = 'hidden';

				const animation = content.animate(
					[
						{ height: '0px', opacity: 0, transform: 'translateY(-4px)' },
						{ height: endHeight, opacity: 1, transform: 'translateY(0)' },
					],
					{ duration, easing },
				);

				animation.onfinish = () => {
					content.style.height = '';
					content.style.overflow = '';
					delete details.dataset.animating;
				};
				animation.oncancel = () => {
					content.style.height = '';
					content.style.overflow = '';
					delete details.dataset.animating;
				};
			});
		});
	}

	function bindDs2Select() {
		document.querySelectorAll<HTMLElement>('[data-ds-select]').forEach((select) => {
			if (select.dataset.selectBound) return;
			select.dataset.selectBound = '1';

			const trigger = select.querySelector<HTMLButtonElement>('.ds-select-trigger');
			const value = select.querySelector<HTMLElement>('.ds-select-value');
			const input = select.querySelector<HTMLInputElement>('[data-ds-select-input]');
			const items = select.querySelectorAll<HTMLButtonElement>('.ds-select-item');

			const close = () => {
				select.removeAttribute('data-open');
				trigger?.setAttribute('aria-expanded', 'false');
			};

			const open = () => {
				select.setAttribute('data-open', 'true');
				trigger?.setAttribute('aria-expanded', 'true');
			};

			trigger?.addEventListener('click', (event) => {
				event.stopPropagation();
				if (select.getAttribute('data-open') === 'true') {
					close();
					return;
				}
				open();
			});

			items.forEach((item) => {
				item.addEventListener('click', (event) => {
					event.stopPropagation();
					const nextValue = item.dataset.value ?? item.textContent?.trim() ?? '';
					if (value) value.textContent = nextValue;
					if (input) input.value = nextValue;

					items.forEach((currentItem) => {
						const isSelected = currentItem === item;
						currentItem.classList.toggle('is-selected', isSelected);
						currentItem.setAttribute('aria-selected', isSelected ? 'true' : 'false');
					});

					close();
				});
			});

			select.addEventListener('keydown', (event) => {
				if (event.key === 'Escape') close();
			});

			document.addEventListener('click', (event) => {
				const target = event.target;
				if (target instanceof Node && !select.contains(target)) close();
			});
		});
	}

	bindDs2Faq();
	bindDs2Select();
	document.addEventListener('astro:page-load', bindDs2Faq);
	document.addEventListener('astro:page-load', bindDs2Select);
</script>

