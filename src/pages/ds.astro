	:global(.ds-select-chevron) {
		flex: 0 0 auto;
		opacity: 0.6;
		transform: rotate(90deg);
		transition:
			opacity 200ms ease,
			transform 200ms ease;
	}

	:global(.ds-select[data-open="true"] .ds-select-chevron) {
		opacity: 1;
		transform: rotate(-90deg);
	}

	.ds-select-content {
		position: absolute;
		top: calc(100% + 6px);
		right: 0;
		left: 0;
		z-index: 50;
		overflow: hidden;
		border-radius: 10px;
		border: 1px solid var(--ds-border);
		background: #ffffff;
		color: #18181b;
		box-shadow: 0 18px 48px -22px rgba(0, 0, 0, 0.32);
		opacity: 0;
		pointer-events: none;
		transform: translateY(-8px) scale(0.96);
		transform-origin: top center;
		visibility: hidden;
		transition:
			opacity 180ms ease,
			transform 180ms ease,
			visibility 180ms ease;
	}

	.ds-select[data-open="true"] .ds-select-content {
		animation: ds-select-in 180ms ease-out;
		opacity: 1;
		pointer-events: auto;
		transform: translateY(0) scale(1);
		visibility: visible;
	}

