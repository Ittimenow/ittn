		border-color: var(--ds-border);
		box-shadow: 0 0 0 4px rgba(113, 113, 122, 0.16);
	}

	.ds-check,
	.ds-toggle {
		display: flex;
		min-height: 48px;
		align-items: center;
		gap: 10px;
		border-radius: 16px;
		border: 1px solid #e4e4e7;
		padding: 0 14px;
		color: #3f3f46;
		font-size: 14px;
	}

	.ds-check input {
		width: 16px;
		height: 16px;
		accent-color: var(--ds-primary);
	}

	.ds-toggle input {
		position: absolute;
		opacity: 0;
		pointer-events: none;
	}

	.ds-toggle span {
		position: relative;
		display: block;
		width: 42px;
		height: 24px;
		border-radius: 9999px;
		background: #d4d4d8;
	}

	.ds-toggle span::after {
		position: absolute;
		top: 3px;
		left: 3px;
		width: 18px;
		height: 18px;
		border-radius: 9999px;
		background: #ffffff;
		content: "";
		transition: transform 150ms ease;
	}

	.ds-toggle input:checked + span {
		background: var(--ds-primary);
	}

	.ds-toggle input:checked + span::after {
		transform: translateX(18px);
	}

