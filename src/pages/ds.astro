		width: 100%;
		min-height: 38px;
		align-items: center;
		justify-content: space-between;
		gap: 10px;
		border-radius: 8px;
		border: 1px solid var(--ds-border);
		background: #ffffff;
		padding: 0 14px;
		color: #18181b;
		text-align: left;
		box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
		outline: none;
		transition:
			border-color 180ms ease,
			box-shadow 180ms ease,
			background 180ms ease,
			color 180ms ease;
	}

