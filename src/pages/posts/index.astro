---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('posts', ({ data }) => !data.draft)).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<Layout title="Блог — ittimenow" description="Заметки команды ittimenow о разработке, ИИ и автоматизации.">
	<section class="mx-auto max-w-4xl px-6 py-16 sm:py-24">
		<p class="text-sm font-medium text-fuchsia-600 dark:text-fuchsia-400">Журнал</p>
		<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">Блог</h1>
		<p class="mt-4 max-w-2xl text-lg text-neutral-600 dark:text-neutral-400">
			Заметки о разработке, внедрениях и ИИ в боевых проектах.
		</p>

		<div class="mt-12">
			{posts.length === 0 ? (
				<p class="rounded-xl border border-dashed border-neutral-300 p-10 text-center text-neutral-500 dark:border-neutral-800">
					Пока пусто — добавь markdown в <code class="text-neutral-700 dark:text-neutral-300">src/content/posts</code>.
				</p>
			) : (
				<ul class="divide-y divide-neutral-200 overflow-hidden rounded-2xl border border-neutral-200 dark:divide-neutral-800 dark:border-neutral-800">
					{posts.map((post) => (
						<li>
							<a
								href={`/posts/${post.id}/`}
								class="flex flex-col gap-2 bg-white p-6 transition hover:bg-neutral-50 sm:flex-row sm:items-center sm:justify-between dark:bg-neutral-900/30 dark:hover:bg-neutral-900/70"
							>
								<div class="min-w-0">
									<h2
										class="truncate text-lg font-semibold"
										transition:name={`post-${post.id}`}
									>
										{post.data.title}
									</h2>
									<p class="mt-1 line-clamp-1 text-sm text-neutral-600 dark:text-neutral-400">
										{post.data.description}
									</p>
									{post.data.tags.length > 0 && (
										<div class="mt-3 flex flex-wrap gap-1.5">
											{post.data.tags.map((tag) => (
												<span class="rounded-full border border-neutral-200 bg-neutral-50 px-2 py-0.5 text-xs text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
													#{tag}
												</span>
											))}
										</div>
									)}
								</div>
								<time
									datetime={post.data.pubDate.toISOString()}
									class="shrink-0 text-sm tabular-nums text-neutral-500"
								>
									{post.data.pubDate.toLocaleDateString('ru-RU', {
										year: 'numeric',
										month: 'short',
										day: 'numeric',
									})}
								</time>
							</a>
						</li>
					))}
				</ul>
			)}
		</div>
	</section>
</Layout>
