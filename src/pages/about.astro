---
import Layout from '../layouts/Layout.astro';

const team = [
	{ name: 'Разработка', count: '20+', description: 'Фронтенд, бэкенд, мобильная разработка, DevOps.' },
	{ name: 'Внедрение', count: '12+', description: 'Аналитики и консультанты по CRM, ERP, BPM.' },
	{ name: 'ИИ и данные', count: '6+', description: 'Инженеры данных, ML- и LLM-практика.' },
	{ name: 'Поддержка', count: '8+', description: 'Сопровождение, инциденты 24/7, обучение.' },
];
---

<Layout title="О компании — ittimenow" description="ittimenow — IT-команда с 2013 года: разработка, автоматизация, ИИ.">
	<section class="mx-auto max-w-4xl px-6 py-16 sm:py-24">
		<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">О компании</p>
		<h1 class="mt-2 text-4xl font-bold tracking-tight sm:text-5xl">
			Делаем IT для бизнеса с 2013 года
		</h1>
		<p class="mt-6 text-lg text-neutral-600 dark:text-neutral-400">
			ittimenow — команда разработки, внедрения и сопровождения. Помогаем
			бизнесу запускать цифровые продукты, автоматизировать процессы и
			внедрять ИИ без хайпа — с понятной экономикой и SLA.
		</p>
		<p class="mt-4 text-lg text-neutral-600 dark:text-neutral-400">
			За 10+ лет реализовали более 150 проектов для страхования,
			девелопмента, ритейла, банков и промышленности.
		</p>

		<div class="mt-12 grid gap-4 sm:grid-cols-2">
			{team.map((t) => (
				<div class="rounded-2xl border border-neutral-200 bg-white p-6 dark:border-neutral-800 dark:bg-neutral-900/40">
					<p class="text-3xl font-semibold">{t.count}</p>
					<p class="mt-1 text-sm font-medium text-indigo-600 dark:text-indigo-400">{t.name}</p>
					<p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{t.description}</p>
				</div>
			))}
		</div>

		<div class="mt-16 rounded-3xl border border-neutral-200 bg-gradient-to-br from-indigo-50 to-fuchsia-50 p-8 sm:p-12 dark:border-neutral-800 dark:from-indigo-950/40 dark:to-fuchsia-950/40">
			<h2 class="text-2xl font-semibold">Контакты</h2>
			<dl class="mt-6 grid gap-4 sm:grid-cols-3 text-sm">
				<div>
					<dt class="text-neutral-500">Телефон</dt>
					<dd class="mt-1 font-medium">
						<a href="tel:+74951335888" class="hover:text-indigo-600 dark:hover:text-indigo-400">
							+7 (495) 133-58-88
						</a>
					</dd>
				</div>
				<div>
					<dt class="text-neutral-500">Email</dt>
					<dd class="mt-1 font-medium">
						<a href="mailto:hello@ittimenow.com" class="hover:text-indigo-600 dark:hover:text-indigo-400">
							hello@ittimenow.com
						</a>
					</dd>
				</div>
				<div>
					<dt class="text-neutral-500">Офис</dt>
					<dd class="mt-1 font-medium">Москва, Варшавское ш., 28А</dd>
				</div>
			</dl>
		</div>
	</section>
</Layout>
