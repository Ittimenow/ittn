---
import Layout from '../layouts/Layout.astro';
import UiIcon from '../components/UiIcon.astro';

const colors = [
	{ name: 'Electric Blue', role: 'Primary brand, links, headings', value: '#232BFF' },
	{ name: 'Vivid Blue', role: 'Primary buttons', value: '#006AFF' },
	{ name: 'Black', role: 'Primary text', value: '#000000' },
	{ name: 'Medium Gray', role: 'Metadata, disabled context', value: '#5F6673' },
	{ name: 'Off White', role: 'Subtle page surfaces', value: '#F1F1F1' },
	{ name: 'Dark Slate', role: 'Borders, surface accents', value: '#424956' },
	{ name: 'Error Red', role: 'Validation and danger states', value: '#FF2121' },
];

const typeScale = [
	{ role: 'Display', size: '54px', weight: '700', leading: '54px', usage: 'Hero headlines' },
	{ role: 'Heading 1', size: '30px', weight: '400', leading: '30px', usage: 'Section headings' },
	{ role: 'Heading 2', size: '18px', weight: '400', leading: '21.6px', usage: 'Card titles' },
	{ role: 'Body Large', size: '18px', weight: '400', leading: '30.6px', usage: 'Primary copy' },
	{ role: 'Body', size: '14px', weight: '400', leading: 'Normal', usage: 'Standard text' },
	{ role: 'Caption', size: '12px', weight: '400', leading: '15.6px', usage: 'Fine print' },
];

const textBadges = ['CRM', 'AI audit', 'Enterprise', 'SLA 24/7', 'Integration'];

const textListItems = [
	'Описывать результат через бизнес-действие, а не через абстрактную возможность.',
	'Держать пункты списков короткими: одна мысль на строку.',
	'Выделять ключевые статусы синим, ошибки — красным, справочный текст — серым.',
];

const spacing = ['4', '8', '12', '16', '20', '24', '28', '32', '40', '52', '56', '60'];

const breakpoints = [
	{ name: 'Mobile', width: '320-640px', behavior: 'Single column, 16px side padding, compact type.' },
	{ name: 'Tablet', width: '641-1024px', behavior: 'Two columns, 24px side padding, reduced sections.' },
	{ name: 'Desktop', width: '1025-1440px', behavior: '3-4 columns, 12-column grid, visible navigation.' },
	{ name: 'Large Desktop', width: '1441px+', behavior: 'Centered 1400px container, expanded multi-column layouts.' },
];

const rules = [
	'Use #232BFF for core brand interactions: CTAs, links, key headings.',
	'Keep body text black; reserve grays for secondary or disabled information.',
	'Cards and major containers stay sharp with 0px radius.',
	'Use 40px, 56px, and 60px vertical spacing for section rhythm.',
	'Inputs use 16px padding, 51px height, and a blue focus outline.',
	'Keep animations under 0.3s and use them only for clear feedback.',
];

const priceBadges = [
	{
		tag: 'Старт',
		title: 'Аудит и дорожная карта',
		description: 'Когда нужно понять, что именно настраивать и сколько это будет стоить.',
		price: 'от 19 000 ₽',
		icon: 'filter',
		items: ['интервью с заказчиком', 'разбор текущих процессов', 'выбор облака или коробки', 'карта автоматизации', 'смета и этапы запуска'],
	},
	{
		tag: 'Популярно',
		title: 'Быстрый старт CRM',
		description: 'Для малого бизнеса и первого запуска Bitrix24.',
		price: 'от 39 000 ₽',
		icon: 'rocket',
		items: ['настройка портала', 'пользователи, роли и права', 'базовая CRM', '1-2 воронки', 'почта или форма', 'обучение ответственного'],
		featured: true,
	},
	{
		tag: 'Продажи',
		title: 'Отдел продаж под ключ',
		description: 'Когда нужен управляемый отдел продаж, а не просто “поставить CRM”.',
		price: 'от 89 000 ₽',
		icon: 'users',
		items: ['аудит продаж', 'воронки и карточки', 'роботы и автоматизация', 'телефония, почта, формы', 'шаблоны документов', 'отчеты для руководителя'],
	},
	{
		tag: 'Процессы',
		title: 'Комплексное внедрение',
		description: 'Для продаж, внутренних процессов, согласований, интеграций и аналитики.',
		price: 'от 149 000 ₽',
		icon: 'workflow',
		items: ['бизнес-анализ', 'CRM, задачи и процессы', 'смарт-процессы', 'интеграции с 1С', 'миграция данных', 'запуск и сопровождение'],
	},
	{
		tag: 'Enterprise',
		title: 'Коробка и сложные интеграции',
		description: 'Для требований к безопасности, инфраструктуре, кастомизации и интеграциям.',
		price: 'от 249 000 ₽',
		icon: 'shield',
		items: ['архитектура внедрения', 'коробочная версия', 'API-интеграции', 'нестандартные модули', 'права сложной структуры', 'оптимизация портала'],
	},
];
---

<Layout
	title="Дизайн-система IT Time Now"
	description="Цвета, типографика, компоненты, сетка и правила интерфейса IT Time Now."
	headerVariant="glass"
>
	<section class="border-b border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-950">
		<div class="mx-auto grid max-w-[1400px] gap-10 px-6 py-16 sm:py-20 lg:grid-cols-[1.15fr_0.85fr] lg:px-8">
			<div>
				<p class="text-sm font-semibold uppercase text-[#232BFF]">Design system</p>
				<h1 class="mt-4 max-w-4xl text-[42px] font-bold leading-none text-black sm:text-[54px] dark:text-white">
					IT Time Now: electric blue, clean structure, enterprise clarity
				</h1>
				<p class="mt-6 max-w-2xl text-lg leading-[30.6px] text-neutral-700 dark:text-neutral-300">
					Система фиксирует визуальный язык бренда: насыщенный синий акцент, строгую типографику,
					острые поверхности, мягкую глубину и понятные компоненты для цифровых продуктов.
				</p>
				<div class="mt-8 flex flex-wrap gap-3">
					<a
						href="#components"
						class="inline-flex min-h-11 items-center rounded-[10px] bg-[#006AFF] px-4 py-[11px] text-sm font-bold leading-[23.8px] text-white transition hover:bg-[#1D24D9] hover:shadow-[rgba(33,33,33,0.2)_0px_8px_6px_-6px]"
					>
						Компоненты
					</a>
					<a
						href="#text-styles"
						class="inline-flex min-h-11 items-center border-b-2 border-transparent pt-3 text-sm text-black transition hover:border-[#232BFF] hover:text-[#232BFF] dark:text-white"
					>
						Текстовые стили
					</a>
					<a
						href="#rules"
						class="inline-flex min-h-11 items-center border-b-2 border-transparent pt-3 text-sm text-black transition hover:border-[#232BFF] hover:text-[#232BFF] dark:text-white"
					>
						Правила применения
					</a>
				</div>
			</div>

			<div class="grid content-start gap-4">
				<div class="bg-[#232BFF] p-8 text-white shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px]">
					<p class="text-sm">Primary accent</p>
					<p class="mt-8 text-4xl font-bold">#232BFF</p>
				</div>
				<div class="grid grid-cols-3 gap-4">
					<div class="h-24 bg-[#006AFF]"></div>
					<div class="h-24 bg-[#232BFF]"></div>
					<div class="h-24 bg-black dark:bg-white"></div>
				</div>
			</div>
		</div>
	</section>

	<section class="mx-auto max-w-[1400px] px-6 py-14 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
			<div>
				<p class="text-sm font-semibold uppercase text-[#232BFF]">01 / Colors</p>
				<h2 class="mt-3 text-[30px] leading-[30px] text-black dark:text-white">Цвета и роли</h2>
				<p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
					Синий остается главным сигналом бренда. Нейтральные цвета удерживают контраст и деловой тон.
				</p>
			</div>
			<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
				{colors.map((color) => (
					<article class="bg-white p-6 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<div class="h-24 border border-neutral-200 dark:border-neutral-800" style={`background:${color.value}`}></div>
						<h3 class="mt-5 text-lg leading-[21.6px] text-black dark:text-white">{color.name}</h3>
						<p class="mt-2 font-mono text-xs text-[#232BFF]">{color.value}</p>
						<p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">{color.role}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="bg-[#F1F1F1] dark:bg-neutral-900/60">
		<div class="mx-auto max-w-[1400px] px-6 py-14 lg:px-8">
			<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
				<div>
					<p class="text-sm font-semibold uppercase text-[#232BFF]">02 / Typography</p>
					<h2 class="mt-3 text-[30px] leading-[30px] text-black dark:text-white">Типографика</h2>
					<p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
						Основной стек использует TT Runs для заголовков, текста и интерфейса. Helvetica Neue применяется для малых UI-лейблов.
					</p>
				</div>
				<div class="overflow-hidden bg-white shadow-[rgba(0,0,0,0.1)_0px_2px_5px_0px] dark:bg-neutral-950">
					<div class="grid grid-cols-[1fr_90px_90px_90px] border-b border-neutral-200 px-5 py-3 text-xs font-semibold uppercase text-neutral-500 dark:border-neutral-800 max-md:hidden">
						<span>Role</span>
						<span>Size</span>
						<span>Weight</span>
						<span>Line</span>
					</div>
					{typeScale.map((type) => (
						<div class="grid gap-3 border-b border-neutral-200 px-5 py-5 last:border-0 dark:border-neutral-800 md:grid-cols-[1fr_90px_90px_90px]">
							<div>
								<p class="text-black dark:text-white" style={`font-size:${type.size};line-height:${type.leading === 'Normal' ? 'normal' : type.leading};font-weight:${type.weight}`}>
									{type.role}
								</p>
								<p class="mt-2 text-sm text-neutral-600 dark:text-neutral-400">{type.usage}</p>
							</div>
							<p class="text-sm text-neutral-700 dark:text-neutral-300">{type.size}</p>
							<p class="text-sm text-neutral-700 dark:text-neutral-300">{type.weight}</p>
							<p class="text-sm text-neutral-700 dark:text-neutral-300">{type.leading}</p>
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section id="text-styles" class="mx-auto max-w-[1400px] px-6 py-14 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
			<div>
				<p class="text-sm font-semibold uppercase text-[#232BFF]">03 / Text styles</p>
				<h2 class="mt-3 text-[30px] leading-[30px] text-black dark:text-white">Текстовые стили</h2>
				<p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
					Примеры показывают, как собирать текстовые блоки, списки, плашки и служебные состояния в интерфейсе.
				</p>
			</div>

			<div class="grid gap-5">
				<div class="grid gap-5 lg:grid-cols-[1.15fr_0.85fr]">
					<article class="bg-white p-7 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<p class="text-sm font-semibold uppercase text-[#232BFF]">Editorial block</p>
						<h3 class="mt-4 max-w-2xl text-[30px] leading-[30px] text-black dark:text-white">
							Единый стиль текста для продуктовых страниц и внутренних интерфейсов
						</h3>
						<p class="mt-5 max-w-3xl text-lg leading-[30.6px] text-neutral-700 dark:text-neutral-300">
							Крупный вводный абзац нужен для объяснения контекста. Он держит спокойный деловой тон,
							не конкурирует с заголовком и помогает быстро понять ценность блока.
						</p>
						<p class="mt-4 max-w-3xl text-sm leading-6 text-neutral-600 dark:text-neutral-400">
							Основной текст остается компактным: 14px, нормальный вес, достаточный интерлиньяж.
							Ссылки и важные термины подсвечиваются <a href="#rules" class="font-semibold text-[#232BFF] underline decoration-[#232BFF]/25 underline-offset-4 hover:decoration-[#232BFF]">электрическим синим</a>.
						</p>
					</article>

					<article class="border-l-4 border-[#232BFF] bg-white p-7 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<p class="text-sm font-semibold uppercase text-[#232BFF]">Quote / Note</p>
						<blockquote class="mt-4 text-[22px] leading-[30px] text-black dark:text-white">
							“Текст в интерфейсе должен сокращать путь к действию, а не объяснять сам интерфейс.”
						</blockquote>
						<p class="mt-5 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
							Используйте такие блоки для принципов, важных ограничений и смысловых акцентов.
						</p>
					</article>
				</div>

				<div class="grid gap-5 md:grid-cols-3">
					<article class="bg-white p-6 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Маркированный список</h3>
						<ul class="mt-5 space-y-3 text-sm leading-6 text-neutral-700 dark:text-neutral-300">
							{textListItems.map((item) => (
								<li class="flex gap-3">
									<span class="mt-[9px] h-1.5 w-1.5 shrink-0 bg-[#232BFF]"></span>
									<span>{item}</span>
								</li>
							))}
						</ul>
					</article>

					<article class="bg-white p-6 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Плашки и теги</h3>
						<div class="mt-5 flex flex-wrap gap-2">
							{textBadges.map((badge) => (
								<span class="inline-flex min-h-8 items-center gap-2 rounded-full border border-neutral-300 bg-white px-3 text-xs font-semibold leading-none text-neutral-800 shadow-[rgba(0,0,0,0.08)_0px_2px_6px_0px] dark:border-neutral-700 dark:bg-neutral-950 dark:text-neutral-100">
									<span class="h-1.5 w-1.5 rounded-full bg-[#232BFF]"></span>
									<span>{badge}</span>
								</span>
							))}
						</div>
						<div class="mt-6 grid gap-2">
							<span class="inline-flex w-fit items-center bg-[#232BFF] px-3 py-2 text-xs font-bold uppercase text-white">Active status</span>
							<span class="inline-flex w-fit items-center border border-neutral-300 bg-[#F1F1F1] px-3 py-2 text-xs font-bold uppercase text-[#5F6673] dark:border-neutral-700 dark:bg-neutral-800 dark:text-neutral-300">Draft state</span>
							<span class="inline-flex w-fit items-center gap-2 border border-neutral-300 bg-white px-3 py-2 text-xs font-bold uppercase text-[#FF2121] dark:border-neutral-700 dark:bg-neutral-950">
								<span class="h-2 w-2 bg-[#FF2121]"></span>
								<span>Error label</span>
							</span>
						</div>
					</article>

					<article class="bg-white p-6 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Служебный текст</h3>
						<dl class="mt-5 grid gap-4">
							<div>
								<dt class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400">Caption</dt>
								<dd class="mt-1 text-xs leading-[15.6px] text-neutral-600 dark:text-neutral-300">Обновлено 16 мая 2026</dd>
							</div>
							<div>
								<dt class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400">Helper text</dt>
								<dd class="mt-1 text-sm leading-6 text-neutral-600 dark:text-neutral-300">Показывает ограничение поля, формат данных или следующий шаг.</dd>
							</div>
							<div>
								<dt class="text-xs font-semibold uppercase text-neutral-500 dark:text-neutral-400">Inline code</dt>
								<dd class="mt-2"><code class="bg-[#F1F1F1] px-2 py-1 font-mono text-xs text-[#232BFF] dark:bg-neutral-800">crm.status.active</code></dd>
							</div>
						</dl>
					</article>
				</div>
			</div>
		</div>
	</section>

	<section id="components" class="mx-auto max-w-[1400px] px-6 py-14 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
			<div>
				<p class="text-sm font-semibold uppercase text-[#232BFF]">04 / Components</p>
				<h2 class="mt-3 text-[30px] leading-[30px] text-black dark:text-white">Компоненты</h2>
				<p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400">
					Базовые состояния показывают кнопки, карточки, ссылки и поля форм в рабочем интерфейсном контексте.
				</p>
			</div>

			<div class="grid gap-5">
				<div class="grid gap-5 md:grid-cols-2">
					<div class="bg-white p-7 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Buttons</h3>
						<div class="mt-6 flex flex-wrap items-center gap-4">
							<button class="min-h-[49.8px] rounded-full bg-[#232BFF] px-6 py-[11px] text-sm font-bold leading-[23.8px] text-white transition hover:bg-[#006AFF] hover:shadow-[rgba(33,33,33,0.2)_0px_8px_6px_-6px]">
								Button variant 1
							</button>
							<button class="min-h-[49.8px] rounded-full border-2 border-[#232BFF] bg-transparent px-6 py-[9px] text-sm font-bold leading-[23.8px] text-[#232BFF] transition hover:bg-[#232BFF] hover:text-white">
								Button variant 2
							</button>
							<button class="btn-liquid" type="button">
								<span class="btn-liquid-lens"></span>
								<span class="btn-liquid-text">Button variant 5</span>
							</button>
							<button aria-label="Next" class="flex h-11 w-11 items-center justify-center rounded-full bg-[#232BFF] text-white transition hover:bg-[#1D24D9]">
								→
							</button>
						</div>
					</div>

					<div class="bg-white p-7 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Form fields</h3>
						<label class="mt-6 block text-[13px] leading-[15px] text-black dark:text-white" for="example-name">Имя</label>
						<input
							id="example-name"
							class="mt-2 h-[51px] w-full rounded-[10px] bg-white px-4 text-sm text-[#1F2937] outline-none ring-0 transition placeholder:text-[#999999] focus:border-2 focus:border-[#232BFF] focus:shadow-[rgba(35,43,255,0.1)_0px_0px_0px_3px] dark:bg-neutral-950 dark:text-white"
							placeholder="Ваше имя"
						/>
						<label class="mt-4 block text-[13px] leading-[15px] text-black dark:text-white" for="example-message">Комментарий</label>
						<textarea
							id="example-message"
							class="mt-2 min-h-[120px] w-full rounded-[10px] border-2 border-[#424956] bg-white px-4 py-4 text-sm text-[#1F2937] outline-none transition focus:border-[#232BFF] focus:shadow-[rgba(35,43,255,0.1)_0px_0px_0px_3px] dark:bg-neutral-950 dark:text-white"
						>Короткое описание задачи</textarea>
					</div>
				</div>

				<div class="grid gap-5 md:grid-cols-3">
					<article class="bg-white p-6 shadow-[rgba(61,61,61,0.09)_0px_2px_18px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Default card</h3>
						<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">Белая поверхность, острые углы, мягкая тень.</p>
					</article>
					<article class="border-l-4 border-[#232BFF] bg-white p-7 shadow-[rgba(0,0,0,0.09)_-1px_-1px_1px_0px] dark:bg-neutral-900">
						<h3 class="text-[30px] leading-[30px] text-[#232BFF]">Accent card</h3>
						<p class="mt-4 text-sm leading-6 text-neutral-600 dark:text-neutral-400">Синий левый бордер для ключевых смысловых блоков.</p>
					</article>
					<article class="bg-white p-8 shadow-[rgba(0,0,0,0.1)_0px_2px_5px_0px] dark:bg-neutral-900">
						<h3 class="text-lg leading-[21.6px] text-black dark:text-white">Elevated card</h3>
						<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">Используется для поднятых контейнеров и важных панелей.</p>
					</article>
				</div>

				<div class="bg-[#F1F1F1] p-5 dark:bg-neutral-900/60 sm:p-7">
