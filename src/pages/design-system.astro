	<section id="rules" class="mx-auto max-w-[1400px] px-6 py-14 lg:px-8">
		<div class="grid gap-8 lg:grid-cols-[320px_1fr]">
			<div>
				<p class="text-sm font-semibold uppercase text-[#232BFF]">06 / Guide</p>
