<svg class="pointer-events-none absolute h-0 w-0 overflow-hidden" aria-hidden="true">
	<filter id="liquid-glass-v5" primitiveUnits="objectBoundingBox">
		<feTurbulence type="fractalNoise" baseFrequency="0.012 0.045" numOctaves="2" seed="8" result="map" />
		<feGaussianBlur in="SourceGraphic" stdDeviation="0.01" result="blur" />
		<feDisplacementMap
			in="blur"
			in2="map"
			scale="0.5"
			xChannelSelector="R"
			yChannelSelector="G"
		/>
	</filter>
</svg>

<style>
	.btn-liquid {
		appearance: none;
		position: relative;
		isolation: isolate;
		display: inline-flex;
		align-items: center;
		justify-content: center;
		gap: 8px;
		border: none;
		border-radius: 9999px;
		background: transparent;
		color: rgba(0, 0, 0, 0.95);
		cursor: pointer;
		font: inherit;
		font-size: 16px;
		font-weight: 500;
		letter-spacing: 0;
		line-height: 1.2;
		padding: 14px 24px;
		transition: transform 300ms ease-out;
		--glass-reflex-light: 1;
		--glass-reflex-dark: 1;
	}

	.btn-liquid-lens {
		position: absolute;
		inset: 0;
		z-index: -1;
		border-radius: inherit;
		background-color: rgba(255, 255, 255, 0.24);
		backdrop-filter: blur(8px) url("#liquid-glass-v5") saturate(150%);
		-webkit-backdrop-filter: blur(8px) saturate(150%);
		box-shadow:
			inset 0 0 0 1px color-mix(in srgb, white calc(var(--glass-reflex-light) * 10%), transparent),
			inset 1.8px 3px 0 -2px color-mix(in srgb, white calc(var(--glass-reflex-light) * 90%), transparent),
			inset -2px -2px 0 -2px color-mix(in srgb, white calc(var(--glass-reflex-light) * 80%), transparent),
			inset -3px -8px 1px -6px color-mix(in srgb, white calc(var(--glass-reflex-light) * 60%), transparent),
			inset -0.3px -1px 4px 0 color-mix(in srgb, black calc(var(--glass-reflex-dark) * 12%), transparent),
			inset -1.5px 2.5px 0 -2px color-mix(in srgb, black calc(var(--glass-reflex-dark) * 20%), transparent),
			inset 0 3px 4px -2px color-mix(in srgb, black calc(var(--glass-reflex-dark) * 20%), transparent),
			inset 2px -6.5px 1px -4px color-mix(in srgb, black calc(var(--glass-reflex-dark) * 10%), transparent),
			0 1px 5px 0 color-mix(in srgb, black calc(var(--glass-reflex-dark) * 10%), transparent),
			0 6px 16px 0 color-mix(in srgb, black calc(var(--glass-reflex-dark) * 8%), transparent);
		pointer-events: none;
		transition:
			background-color 400ms cubic-bezier(1, 0, 0.4, 1),
			box-shadow 400ms cubic-bezier(1, 0, 0.4, 1);
	}

	.btn-liquid-text {
		position: relative;
		z-index: 1;
		display: flex;
		width: 100%;
		align-items: center;
		justify-content: center;
		gap: inherit;
		color: #232bff;
		text-shadow: 0 1px 2px rgba(255, 255, 255, 0.3);
		user-select: none;
		transition: color 400ms cubic-bezier(1, 0, 0.4, 1);
	}

	@media (hover: hover) {
		.btn-liquid:not(:disabled):hover {
			transform: scale(1.03);
		}
	}

	.btn-liquid:not(:disabled):active {
		transform: scale(0.96);
	}

	.price-badge-card {
		position: relative;
		isolation: isolate;
		overflow: hidden;
		border: 2px solid transparent;
		border-radius: 22px;
		--rotation: 4.2rad;
		--badge-bg: #ffffff;
		--badge-accent: #232bff;
		--badge-shadow: rgba(35, 43, 255, 0.16);
		background-image:
			linear-gradient(var(--badge-bg), var(--badge-bg)),
			linear-gradient(
				calc(var(--rotation) + 0rad),
				color-mix(in srgb, var(--badge-accent) 95%, white) 0%,
				color-mix(in srgb, var(--badge-accent) 42%, transparent) 24%,
				rgba(255, 255, 255, 0) 72%
			);
		background-origin: border-box;
		background-clip: padding-box, border-box;
		box-shadow:
			0 2px 18px rgba(61, 61, 61, 0.09),
			0 0 0 rgba(35, 43, 255, 0);
		transition:
			transform 220ms ease,
			box-shadow 220ms ease,
			border-color 220ms ease;
	}

	.price-badge-card::before {
		position: absolute;
		inset: -35%;
		z-index: -1;
		content: "";
		border-radius: inherit;
		background:
			radial-gradient(
				circle at var(--glow-x, 50%) var(--glow-y, 50%),
				color-mix(in srgb, var(--badge-accent) 34%, transparent) 0%,
				rgba(35, 43, 255, 0.12) 24%,
				transparent 58%
			);
		opacity: 0;
		transition: opacity 220ms ease;
	}

	.price-badge-card.is-featured {
		--badge-shadow: rgba(35, 43, 255, 0.24);
	}

	@media (hover: hover) {
		.price-badge-card:hover {
			transform: translateY(-4px);
			box-shadow:
				0 16px 38px -24px rgba(0, 0, 0, 0.55),
				0 0 34px -16px var(--badge-shadow);
		}

		.price-badge-card:hover::before {
			opacity: 1;
		}
	}

	:global(.dark) .price-badge-card {
		--badge-bg: #0a0a0a;
		--badge-shadow: rgba(35, 43, 255, 0.28);
		box-shadow:
			0 2px 18px rgba(0, 0, 0, 0.26),
			0 0 0 rgba(35, 43, 255, 0);
	}
</style>
<script>
	const priceBadgeCards = document.querySelectorAll<HTMLElement>('[data-price-badge-card]');

	priceBadgeCards.forEach((card) => {
		card.addEventListener('pointermove', (event) => {
			const rect = card.getBoundingClientRect();
			const x = event.clientX - rect.left;
			const y = event.clientY - rect.top;
			const angle = Math.atan2(rect.width / 2 - x, y - rect.height / 2);

			card.style.setProperty('--rotation', `${angle}rad`);
			card.style.setProperty('--glow-x', `${(x / rect.width) * 100}%`);
			card.style.setProperty('--glow-y', `${(y / rect.height) * 100}%`);
		});
	});
</script>
</Layout>
