---
import Layout from '../layouts/Layout.astro';
---

<Layout
	title="Three.js Earth Test"
	description="Тестовый full-viewport блок с медленно вращающейся Землей на Three.js."
	bare
>
	<main class="earth-test" aria-label="Three.js Earth viewport">
		<div id="earth-scene" class="earth-scene"></div>
		<div class="earth-vignette" aria-hidden="true"></div>
	</main>
</Layout>

<style>
	:global(html),
	:global(body) {
		overflow: hidden;
	}

	.earth-test {
		position: fixed;
		inset: 0;
		min-height: 100svh;
		background:
			radial-gradient(circle at 52% 68%, rgba(15, 114, 178, 0.18), transparent 32%),
			radial-gradient(circle at 50% 0%, rgba(114, 169, 220, 0.1), transparent 34%),
			#010308;
		color: white;
	}

	.earth-scene,
	.earth-scene canvas,
	.earth-vignette {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
	}

	.earth-scene canvas {
		display: block;
	}

	.earth-vignette {
		pointer-events: none;
		background:
			linear-gradient(to bottom, rgba(0, 0, 0, 0.76), transparent 23%, transparent 72%, rgba(0, 0, 0, 0.3)),
			radial-gradient(ellipse at 50% 60%, transparent 42%, rgba(0, 0, 0, 0.7) 100%);
	}
</style>

<script>
	import * as THREE from 'three';

	const mount = document.getElementById('earth-scene');

	if (!mount) {
		throw new Error('Earth scene mount was not found.');
	}

	const renderer = new THREE.WebGLRenderer({
		antialias: true,
		alpha: true,
		powerPreference: 'high-performance',
	});
	renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
	renderer.setSize(window.innerWidth, window.innerHeight);
	renderer.outputColorSpace = THREE.SRGBColorSpace;
	renderer.toneMapping = THREE.ACESFilmicToneMapping;
	renderer.toneMappingExposure = 1.08;
	mount.appendChild(renderer.domElement);

	const scene = new THREE.Scene();
	scene.fog = new THREE.FogExp2(0x020612, 0.012);

	const camera = new THREE.PerspectiveCamera(34, window.innerWidth / window.innerHeight, 0.1, 120);
	camera.position.set(0, -1, 8.45);
	camera.lookAt(0, -1.11, 0);

	const earthGroup = new THREE.Group();
	earthGroup.position.set(0, -8.47, 0);
	earthGroup.rotation.set(-0.18, -0.38, 0.02);
	scene.add(earthGroup);

	const sunLight = new THREE.DirectionalLight(0xffffff, 3.7);
	sunLight.position.set(-4.5, 3.2, 4.6);
	scene.add(sunLight);
	scene.add(new THREE.AmbientLight(0x6e90bc, 0.42));

	const textureLoader = new THREE.TextureLoader();
	const loadTexture = (url, colorSpace = THREE.SRGBColorSpace) => {
		const texture = textureLoader.load(url);
		texture.colorSpace = colorSpace;
		texture.anisotropy = renderer.capabilities.getMaxAnisotropy();
		texture.wrapS = THREE.RepeatWrapping;
		texture.wrapT = THREE.ClampToEdgeWrapping;
		return texture;
	};

	const earthMaps = {
		dayMap: loadTexture('/textures/earth/8k_earth_daymap.jpg'),
		nightMap: loadTexture('/textures/earth/8k_earth_nightmap.jpg'),
		normalMap: loadTexture('/textures/earth/8k_earth_normal_map.jpg', THREE.NoColorSpace),
		specularMap: loadTexture('/textures/earth/8k_earth_specular_map.jpg', THREE.NoColorSpace),
		cloudMap: loadTexture('/textures/earth/8k_earth_clouds.jpg'),
	};
	const earthGeometry = new THREE.SphereGeometry(3.45, 160, 160);
	const earth = new THREE.Mesh(
		earthGeometry,
		new THREE.MeshPhongMaterial({
			map: earthMaps.dayMap,
			normalMap: earthMaps.normalMap,
			normalScale: new THREE.Vector2(0.85, 0.85),
			specularMap: earthMaps.specularMap,
			specular: new THREE.Color(0xd7f2ff),
			shininess: 42,
		}),
	);
	earthGroup.add(earth);

	const nightLights = new THREE.Mesh(
		earthGeometry,
		new THREE.ShaderMaterial({
			transparent: true,
			depthWrite: false,
			blending: THREE.AdditiveBlending,
			uniforms: {
				nightMap: { value: earthMaps.nightMap },
				sunDirection: { value: sunLight.position.clone().normalize() },
			},
			vertexShader: `
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				void main() {
					vUv = uv;
					vWorldNormal = normalize(mat3(modelMatrix) * normal);
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform sampler2D nightMap;
				uniform vec3 sunDirection;
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				void main() {
					float night = smoothstep(0.08, -0.24, dot(normalize(vWorldNormal), normalize(sunDirection)));
					vec3 lights = texture2D(nightMap, vUv).rgb;
					float intensity = max(max(lights.r, lights.g), lights.b);
					gl_FragColor = vec4(lights * 1.55, intensity * night * 0.95);
				}
			`,
		}),
	);
	nightLights.scale.setScalar(1.002);
	earthGroup.add(nightLights);

	const waterGlint = new THREE.Mesh(
		earthGeometry,
		new THREE.ShaderMaterial({
			transparent: true,
			depthWrite: false,
			blending: THREE.AdditiveBlending,
			uniforms: {
				specularMap: { value: earthMaps.specularMap },
				sunDirection: { value: sunLight.position.clone().normalize() },
				glintColor: { value: new THREE.Color(0xbfefff) },
			},
			vertexShader: `
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				varying vec3 vWorldPosition;
				void main() {
					vUv = uv;
					vWorldNormal = normalize(mat3(modelMatrix) * normal);
					vec4 worldPosition = modelMatrix * vec4(position, 1.0);
					vWorldPosition = worldPosition.xyz;
					gl_Position = projectionMatrix * viewMatrix * worldPosition;
				}
			`,
			fragmentShader: `
				uniform sampler2D specularMap;
				uniform vec3 sunDirection;
				uniform vec3 glintColor;
				uniform vec3 cameraPosition;
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				varying vec3 vWorldPosition;
				void main() {
					vec3 normal = normalize(vWorldNormal);
					vec3 lightDir = normalize(sunDirection);
					vec3 viewDir = normalize(cameraPosition - vWorldPosition);
					vec3 halfDir = normalize(lightDir + viewDir);
					float oceanMask = texture2D(specularMap, vUv).r;
					float daylight = smoothstep(-0.04, 0.32, dot(normal, lightDir));
					float facing = smoothstep(-0.1, 0.35, dot(normal, viewDir));
					float glint = pow(max(dot(normal, halfDir), 0.0), 86.0);
					float wideGlow = pow(max(dot(normal, halfDir), 0.0), 22.0) * 0.16;
					float alpha = (glint * 2.4 + wideGlow) * oceanMask * daylight * facing;
					gl_FragColor = vec4(glintColor * alpha, alpha);
				}
			`,
		}),
	);
	waterGlint.scale.setScalar(1.004);
	earthGroup.add(waterGlint);

	const clouds = new THREE.Mesh(
		new THREE.SphereGeometry(3.49, 160, 160),
		new THREE.ShaderMaterial({
			transparent: true,
			depthWrite: false,
			uniforms: {
				cloudMap: { value: earthMaps.cloudMap },
				sunDirection: { value: sunLight.position.clone().normalize() },
				cloudColor: { value: new THREE.Color(0xffffff) },
				opacity: { value: 0.85 },
			},
			vertexShader: `
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				void main() {
					vUv = uv;
					vWorldNormal = normalize(mat3(modelMatrix) * normal);
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform sampler2D cloudMap;
				uniform vec3 sunDirection;
				uniform vec3 cloudColor;
				uniform float opacity;
				varying vec2 vUv;
				varying vec3 vWorldNormal;
				void main() {
					vec3 cloudSample = texture2D(cloudMap, vUv).rgb;
					float cloudMask = max(max(cloudSample.r, cloudSample.g), cloudSample.b);
					float daylight = smoothstep(-0.02, 0.18, dot(normalize(vWorldNormal), normalize(sunDirection)));
					float alpha = cloudMask * daylight * opacity;
					gl_FragColor = vec4(cloudColor, alpha);
				}
			`,
		}),
	);
	earthGroup.add(clouds);

	const atmosphere = new THREE.Mesh(
		new THREE.SphereGeometry(3.53, 160, 160),
		new THREE.ShaderMaterial({
			transparent: true,
			depthWrite: false,
			side: THREE.BackSide,
			uniforms: {
				glowColor: { value: new THREE.Color(0x62c6ff) },
			},
			vertexShader: `
				varying vec3 vNormal;
				void main() {
					vNormal = normalize(normalMatrix * normal);
					gl_Position = projectionMatrix * modelViewMatrix * vec4(position, 1.0);
				}
			`,
			fragmentShader: `
				uniform vec3 glowColor;
				varying vec3 vNormal;
				void main() {
					float intensity = pow(0.72 - dot(vNormal, vec3(0.0, 0.0, 1.0)), 2.1);
					gl_FragColor = vec4(glowColor, intensity * 0.78);
				}
			`,
		}),
	);
	earthGroup.add(atmosphere);

	const starsGeometry = new THREE.BufferGeometry();
	const starCount = 950;
	const starPositions = new Float32Array(starCount * 3);
	for (let i = 0; i < starCount; i += 1) {
		const radius = 28 + Math.random() * 28;
		const theta = Math.random() * Math.PI * 2;
		const phi = Math.acos(2 * Math.random() - 1);
		starPositions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
		starPositions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta);
		starPositions[i * 3 + 2] = -Math.abs(radius * Math.cos(phi)) - 5;
	}
	starsGeometry.setAttribute('position', new THREE.BufferAttribute(starPositions, 3));
	const stars = new THREE.Points(
		starsGeometry,
		new THREE.PointsMaterial({
			color: 0xbfdcff,
			size: 0.025,
			transparent: true,
			opacity: 0.55,
			sizeAttenuation: true,
		}),
	);
	scene.add(stars);

	const clock = new THREE.Clock();
	const earthSpinSpeed = 0.01;
	const cloudSpinSpeed = 0.004;
	const lookY = -1.11;

	const resize = () => {
		const width = window.innerWidth;
		const height = window.innerHeight;
		camera.aspect = width / height;
		camera.updateProjectionMatrix();
		renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));
		renderer.setSize(width, height);

		const isPortrait = height > width;
		earthGroup.position.y = isPortrait ? -8.72 : -8.47;
		earthGroup.scale.setScalar(isPortrait ? 2.18 : 2.4);
		camera.position.set(0, -1, 8.45);
		camera.lookAt(0, lookY, 0);
	};

	const animate = () => {
		const delta = Math.min(clock.getDelta(), 0.04);
		earth.rotation.y += delta * earthSpinSpeed;
		nightLights.rotation.y = earth.rotation.y;
		waterGlint.rotation.y = earth.rotation.y;
		clouds.rotation.y += delta * cloudSpinSpeed;
		stars.rotation.y -= delta * 0.002;
		camera.lookAt(0, lookY, 0);
		renderer.render(scene, camera);
		requestAnimationFrame(animate);
	};

	window.addEventListener('resize', resize, { passive: true });
	resize();
	animate();
</script>
