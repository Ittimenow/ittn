---
const directions = [
	{
		title: 'Искусственный интеллект',
		description: 'ИИ-ассистенты, обработка документов, классификация заявок, RAG над корпоративной базой знаний.',
		href: '/services/ai',
		accent: 'from-indigo-500 to-cyan-500',
	},
	{
		title: 'Разработка на заказ',
		description: 'Сайты, личные кабинеты, маркетплейсы, B2B-сервисы. Дизайн, фронтенд, бэкенд, мобильные приложения.',
		href: '/services/web',
		accent: 'from-fuchsia-500 to-rose-500',
	},
	{
		title: 'Внедрение CRM и ERP',
		description: 'Битрикс24, РосБизнесСофт, ЭЛМА. Аудит процессов, интеграции, миграции, обучение.',
		href: '/services/bitrix24',
		accent: 'from-amber-500 to-emerald-500',
	},
];
---

<section class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
	<div class="mb-10">
		<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Услуги</p>
		<h2 class="mt-1 text-3xl font-semibold tracking-tight sm:text-4xl">Три направления</h2>
	</div>

	<div class="grid gap-4 sm:grid-cols-3">
		{directions.map((d) => (
			<a
				href={d.href}
				class="group relative overflow-hidden rounded-2xl border border-neutral-200 bg-white p-6 transition hover:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-neutral-600"
			>
				<div
					aria-hidden="true"
					class={`absolute -top-12 -right-12 h-32 w-32 rounded-full bg-gradient-to-br ${d.accent} opacity-20 blur-2xl transition group-hover:opacity-40`}
				></div>
				<h3 class="text-xl font-semibold">{d.title}</h3>
				<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{d.description}</p>
				<span class="mt-6 inline-flex items-center gap-1 text-sm font-medium text-indigo-600 dark:text-indigo-400">
					Подробнее →
				</span>
			</a>
		))}
	</div>
</section>
