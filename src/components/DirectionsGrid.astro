---
const solutions = [
	{
		label: 'Цифровой канал',
		title: 'Разработка сайтов и сервисов',
		description: 'Корпоративные сайты, B2B-порталы, личные кабинеты, маркетплейсы и внутренние сервисы.',
		when: 'Нужен новый канал продаж, клиентский интерфейс или внутренний инструмент.',
		work: 'UX/UI, frontend, backend, интеграции, развитие продукта.',
		href: '/services/web',
	},
	{
		label: 'Продажи и сервис',
		title: 'CRM для продаж и клиентского сервиса',
		description: 'Bitrix24 и CRM-сценарии для воронки, обращений, телефонии, задач и аналитики.',
		when: 'Заявки теряются, отдел продаж непрозрачен, процессы не закреплены.',
		work: 'Аудит, внедрение, настройка, миграции, обучение.',
		href: '/services/bitrix24',
	},
	{
		label: 'Операционный контур',
		title: 'ERP, BPM и сложная автоматизация',
		description: 'РосБизнесСофт, ЭЛМА и решения для производства, склада, документооборота и маршрутов.',
		when: 'Нужно выстроить операционный контур, а не только CRM.',
		work: 'Моделирование процессов, внедрение, роли, маршруты, интеграции.',
		href: '/services/rbs',
	},
	{
		label: 'Связность данных',
		title: 'Интеграции',
		description: 'Связываем сайт, CRM, ERP, телефонию, мессенджеры, рассылки, 1С и внутренние сервисы.',
		when: 'У компании уже есть набор систем, но между ними нет единой логики.',
		work: 'API, обмены, события, отчётность и контроль качества данных.',
		href: '/services/support',
	},
	{
		label: 'После запуска',
		title: 'Сопровождение и развитие',
		description: 'Поддержка, доработки, аналитика, новые модули, инфраструктура и развитие решения после запуска.',
		when: 'Систему нужно поддерживать, развивать и адаптировать под новые процессы.',
		work: 'SLA, backlog, аналитика, релизы, мониторинг.',
		href: '/services/support',
	},
];
---

<section id="solutions" class="mx-auto max-w-[1440px] px-6 py-16 sm:py-24">
	<div class="mb-10 max-w-3xl">
		<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Наши решения</p>
		<h2 class="mt-2 text-3xl font-semibold leading-tight sm:text-4xl">
			От отдельного сайта до единой цифровой системы компании
		</h2>
		<p class="mt-4 text-neutral-600 dark:text-neutral-400">
			Показываем карту решений простым языком: когда подходит, что входит в работу
			и как решение связано с бизнес-процессом.
		</p>
	</div>

	<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
		{solutions.map((item, index) => (
			<a
				href={item.href}
				class:list={[
					'group flex min-h-80 flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition hover:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-neutral-600',
					index === 0 && 'lg:col-span-2',
				]}
			>
				<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">{item.label}</p>
				<h3 class="mt-3 text-2xl font-semibold leading-tight">{item.title}</h3>
				<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{item.description}</p>
				<div class="mt-6 grid gap-4 text-sm sm:grid-cols-2">
					<div>
						<p class="font-medium text-neutral-950 dark:text-white">Когда подходит</p>
						<p class="mt-2 leading-6 text-neutral-600 dark:text-neutral-400">{item.when}</p>
					</div>
					<div>
						<p class="font-medium text-neutral-950 dark:text-white">Что делаем</p>
						<p class="mt-2 leading-6 text-neutral-600 dark:text-neutral-400">{item.work}</p>
					</div>
				</div>
				<span class="mt-auto pt-6 text-sm font-medium text-indigo-600 dark:text-indigo-400">
					Подробнее →
				</span>
			</a>
		))}
	</div>
</section>
