---
import { getCollection } from 'astro:content';

const all = await getCollection('cases');
const cases = all
	.filter((c) => c.data.featured)
	.sort((a, b) => a.data.order - b.data.order)
	.slice(0, 5);
---

<section class="mx-auto max-w-6xl px-6 py-16 sm:py-24">
	<div class="mb-10 flex items-end justify-between gap-6">
		<div>
			<p class="text-sm font-medium text-fuchsia-600 dark:text-fuchsia-400">Портфолио</p>
			<h2 class="mt-1 text-3xl font-semibold tracking-tight sm:text-4xl">Кейсы</h2>
		</div>
		<a
			href="/cases"
			class="hidden text-sm font-medium text-indigo-600 hover:text-indigo-700 sm:inline dark:text-indigo-400"
		>
			Все кейсы →
		</a>
	</div>

	<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
		{cases.map((c, i) => (
			<a
				href={`/cases/${c.id}/`}
				class:list={[
					'group relative flex flex-col overflow-hidden rounded-2xl border border-neutral-200 bg-white p-6 transition hover:border-neutral-400 dark:border-neutral-800 dark:bg-neutral-900/40 dark:hover:border-neutral-600',
					i === 0 && 'lg:col-span-2 lg:row-span-2',
				]}
				transition:name={`case-${c.id}`}
			>
				<div class="mb-3 flex items-center gap-2 text-xs text-neutral-500">
					<span class="font-medium">{c.data.client}</span>
					{c.data.industry && <><span>·</span><span>{c.data.industry}</span></>}
					{c.data.year && <><span>·</span><span>{c.data.year}</span></>}
				</div>
				<h3 class="text-xl font-semibold leading-tight">{c.data.title}</h3>
				<p class="mt-3 text-sm text-neutral-600 dark:text-neutral-400">{c.data.summary}</p>
				{c.data.stack.length > 0 && (
					<div class="mt-auto pt-6 flex flex-wrap gap-1.5">
						{c.data.stack.slice(0, 4).map((s) => (
							<span class="rounded-full border border-neutral-200 bg-neutral-50 px-2 py-0.5 text-xs text-neutral-600 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-400">
								{s}
							</span>
						))}
					</div>
				)}
			</a>
		))}
	</div>

	<div class="mt-6 sm:hidden">
		<a href="/cases" class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Все кейсы →</a>
	</div>
</section>
