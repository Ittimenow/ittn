---
import UiIcon from './UiIcon.astro';

const heroBenefits = [
	'меньше потерь лидов',
	'выше скорость обработки заявок',
	'меньше ручной работы',
	'прозрачная отчетность',
	'понятные зоны ответственности',
	'единая история коммуникаций',
	'быстрее запуск новых сотрудников',
	'масштабирование продаж без хаоса',
] as const;

const problems = [
	{
		icon: 'message',
		title: 'Единый прием заявок',
		text: 'Заявки с сайта, почты и мессенджеров собираются в одном месте',
	},
	{
		icon: 'filter',
		title: 'Лиды не теряются',
		text: 'Ни один лид не теряется и не забывается',
	},
	{
		icon: 'workflow',
		title: 'Единый сценарий работы',
		text: 'Менеджеры работают по единому сценарию, а не «кто как привык»',
	},
	{
		icon: 'bar-chart',
		title: 'Прозрачная воронка',
		text: 'Руководитель видит прозрачную воронку и реальную загрузку команды',
	},
	{
		icon: 'file',
		title: 'Автоматические документы',
		text: 'Счета, КП, акты, напоминания и уведомления формируются автоматически',
	},
	{
		icon: 'phone',
		title: 'Связанные каналы',
		text: 'Телефония, 1С, сайт, формы, чат-боты и реклама связываются в единую систему',
	},
	{
		icon: 'layers',
		title: 'Согласования в системе',
		text: 'Внутренние согласования и маршруты заявок перестают жить в чатах и таблицах',
	},
	{
		icon: 'database',
		title: 'Чистая клиентская база',
		text: 'База клиентов переносится и очищается от дублей',
	},
	{
		icon: 'users',
		title: 'Быстрый вход в работу',
		text: 'Сотрудники быстрее входят в работу после обучения',
	},
] as const;

const packages = [
	{
		name: 'Аудит и дорожная карта',
		price: 'от 19 000 ₽',
		icon: 'filter',
		tag: 'Старт',
		text: 'Когда нужно понять, что именно настраивать и сколько это будет стоить.',
		items: ['интервью с заказчиком', 'разбор текущих процессов', 'выбор облака или коробки', 'карта автоматизации', 'смета и этапы запуска'],
	},
	{
		name: 'Быстрый старт CRM',
		price: 'от 39 000 ₽',
		icon: 'rocket',
		tag: 'Старт',
		text: 'Для малого бизнеса и первого запуска Bitrix24.',
		items: ['настройка портала', 'пользователи, роли и права', 'базовая CRM', '1-2 воронки', 'почта или форма', 'обучение ответственного'],
	},
	{
		name: 'Отдел продаж под ключ',
		price: 'от 89 000 ₽',
		icon: 'users',
		tag: 'Продажи',
		text: 'Когда нужен управляемый отдел продаж, а не просто «поставить CRM».',
		items: ['аудит продаж', 'воронки и карточки', 'роботы и автоматизация', 'телефония, почта, формы', 'шаблоны документов', 'отчеты для руководителя'],
	},
	{
		name: 'Комплексное внедрение',
		price: 'от 149 000 ₽',
		icon: 'workflow',
		tag: 'Популярно',
		text: 'Для продаж, внутренних процессов, согласований, интеграций и аналитики.',
		featured: true,
		items: ['бизнес-анализ', 'CRM, задачи и процессы', 'смарт-процессы', 'интеграции с 1С', 'миграция данных', 'запуск и сопровождение'],
	},
	{
		name: 'Коробка и сложные интеграции',
		price: 'от 249 000 ₽',
		icon: 'shield',
		tag: 'Enterprise',
		text: 'Для требований к безопасности, инфраструктуре, кастомизации и интеграциям.',
		items: ['архитектура внедрения', 'коробочная версия', 'API-интеграции', 'нестандартные модули', 'права сложной структуры', 'оптимизация портала'],
	},
] as const;

const auditPackage = packages[0];
const implementationPackages = packages.slice(1);

const services = [
	{
		title: 'CRM и продажи',
		icon: 'briefcase',
		items: ['воронки продаж под направления бизнеса', 'карточки лидов, сделок, компаний и контактов', 'повторные продажи и клиентская база', 'KPI менеджеров и контроль отдела продаж'],
	},
	{
		title: 'Автоматизация процессов',
		icon: 'workflow',
		items: ['согласования и маршруты заявок', 'отпуска, закупки, счета и заявки', 'автоматизация документооборота', 'смарт-процессы под нестандартные сценарии'],
	},
	{
		title: 'Интеграции',
		icon: 'layers',
		items: ['1С', 'сайт и интернет-магазин', 'телефония', 'WhatsApp, Telegram, email и чаты', 'маркетплейсы и внешние сервисы'],
	},
	{
		title: 'Данные и миграция',
		icon: 'database',
		items: ['перенос базы клиентов из Excel', 'миграция из amoCRM, Megaplan и других CRM', 'очистка дублей', 'структурирование клиентской базы'],
	},
	{
		title: 'Обучение и сопровождение',
		icon: 'users',
		items: ['обучение сотрудников', 'обучение руководителей аналитике', 'поддержка после запуска', 'абонентское сопровождение'],
	},
	{
		title: 'Индивидуальные доработки',
		icon: 'settings',
		items: ['кастомные модули', 'нестандартные отчеты', 'API-интеграции', 'сложные роли доступа', 'оптимизация медленного портала'],
	},
] as const;

const steps = [
	['filter', 'Аудит', 'Разбираем текущие продажи, каналы заявок, роли, данные и узкие места.'],
	['layers', 'Проектирование', 'Описываем будущую CRM: воронки, карточки, автоматизацию, интеграции и этапы запуска.'],
	['settings', 'Настройка', 'Конфигурируем портал, права, CRM, роботов, формы, телефонию, почту и нужные сервисы.'],
	['rocket', 'Запуск', 'Переносим данные, проверяем сценарии, обучаем команду и запускаем работу в системе.'],
	['bar-chart', 'Сопровождение', 'Следим за первыми результатами, донастраиваем процессы и развиваем портал.'],
] as const;

const clientLogos = [
	{ name: 'Perola Sky', src: '/clients/client-perola.png' },
	{ name: 'William Grant & Sons Ltd.', src: '/clients/client-wgs.png' },
	{ name: 'Альфа-страхование', src: '/clients/client-alfa.png' },
	{ name: 'Донстрой', src: '/clients/client-donstroy.png' },
] as const;

const faqs = [
	['Сколько стоит внедрение Bitrix24?', 'Стоимость зависит от количества пользователей, сложности воронок, интеграций, автоматизации и объема переноса данных. Базовый запуск начинается от 39 000 ₽, комплексные проекты оцениваются после аудита.'],
	['Сколько времени занимает внедрение?', 'Быстрый запуск обычно занимает от нескольких дней до нескольких недель. Проекты с интеграциями, миграцией и сложной логикой могут идти несколько месяцев по этапам.'],
	['Что лучше выбрать: облако или коробку?', 'Облако подходит для быстрого старта и типовых задач. Коробка нужна, если важны кастомизация, контроль инфраструктуры, нестандартные интеграции и повышенные требования к безопасности.'],
	['Можно ли интегрировать Bitrix24 с 1С, телефонией и сайтом?', 'Да. Это частый сценарий: связываем Bitrix24 с 1С, телефонией, почтой, формами, сайтом, кассами, доставкой, аналитикой и внешними сервисами.'],
	['Можно ли перенести клиентскую базу?', 'Да. Обычно переносим лиды, контакты, компании, сделки и базовую историю взаимодействий. Перед импортом проверяем данные на дубли и лишний мусор.'],
	['Нужно ли обучать сотрудников?', 'Да. Без обучения даже хорошо настроенная CRM часто используется частично, поэтому обучение включается в запуск и помогает команде быстрее перейти с таблиц и чатов на единую систему.'],
] as const;

const comparison = [
	['Скорость запуска', '2-5 дней', 'от 4 недель'],
	['Кастомизация', 'типовая логика', 'глубокие доработки'],
	['Инфраструктура', 'на стороне сервиса', 'под контролем компании'],
	['Подходит для', 'быстрого старта продаж', 'сложных требований безопасности'],
] as const;

const checklist = [
	['users', 'Сколько сотрудников'],
	['layers', 'Нужна ли 1С'],
	['phone', 'Нужна ли телефония'],
	['database', 'Есть ли перенос базы'],
] as const;
---

<div class="ds2 bitrix-ds2">
	<section class="ds2-hero bitrix-hero">
		<div class="ds2-container bitrix-hero-grid">
			<div>
				<nav class="bitrix-breadcrumbs" aria-label="Хлебные крошки">
					<a href="/services">Все услуги</a>
					<UiIcon name="chevron" class="h-3.5 w-3.5" />
					<span>Внедрение CRM Bitrix24</span>
				</nav>
				<h1>
					Внедрение и настройка Bitrix24 под ваши процессы
				</h1>
				<p class="bitrix-lead">
					Запустим Bitrix24 от 39 000 ₽: CRM, воронки продаж, роли, карточки, автоматизацию,
					телефонию, почту, формы и интеграции. Поможем выбрать облако или коробку, перенесем
					данные и обучим команду работать без хаоса и Excel.
				</p>
				<div class="bitrix-actions">
					<a class="ds2-btn ds2-btn-primary" href="#bitrix-request">
						<span>Получить расчет</span>
						<UiIcon name="arrow" class="h-4 w-4" />
					</a>
					<a class="ds2-btn ds2-btn-secondary" href="tel:+74951335888">
						<span>Обсудить проект</span>
						<UiIcon name="phone" class="h-4 w-4" />
					</a>
				</div>
				<div class="ds2-testimonial bitrix-hero-benefit">
					<div class="bitrix-hero-benefit-head">
						<UiIcon name="thumbs-up" class="bitrix-hero-benefit-icon h-[52px] w-[52px] shrink-0 text-white/90" />
						<p class="ds2-kicker">Ваша выгода</p>
					</div>
					<blockquote>
						После внедрения Bitrix24 бизнес получает не еще один сервис, а управляемый процесс.
					</blockquote>
					<ul>
						{heroBenefits.map((item) => (
							<li>
								<UiIcon name="check" class="h-4 w-4" />
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<picture class="bitrix-hero-media">
				<img
					src="/main-b24.png"
					alt="Интерфейс Bitrix24 с CRM, задачами и аналитикой"
					width="1086"
					height="1448"
					loading="eager"
					decoding="async"
				/>
			</picture>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
			<div class="ds2-section-head bitrix-wide-head">
				<div>
					<p class="ds2-kicker">Зачем внедрять</p>
					<h2>Bitrix24 нужен не ради CRM, а чтобы убрать потери данных и ручную работу</h2>
				</div>
				<p>
					Внедрение переводит продажи, коммуникации и внутренние процессы в единую рабочую
					систему: заявки не теряются, менеджеры работают по понятной воронке, руководитель
					видит отчеты, а рутинные действия автоматизируются.
				</p>
			</div>

			<div class="bitrix-problems">
				{problems.map(({ icon, title, text }) => (
					<article class="ds2-service-card bitrix-problem-card">
						<div class="ds2-service-icon">
							<UiIcon name={icon} class="h-5 w-5" />
						</div>
						<p>{title}</p>
						<h3>{text}</h3>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Стоимость внедрения</p>
					<h2>Пакеты работ с понятным составом</h2>
				</div>
				<p>
					Лицензия Bitrix24 оплачивается отдельно. Итоговая стоимость зависит от числа
					пользователей, логики, интеграций и объема переноса данных.
				</p>
			</div>
			<div class="bitrix-prices">
				<article class="ds2-price-card bitrix-audit-card">
					<div class="bitrix-card-top">
						<div class="ds2-service-icon">
							<UiIcon name={auditPackage.icon} class="h-5 w-5" />
						</div>
						<span class="ds2-chip">{auditPackage.tag}</span>
					</div>
					<div class="bitrix-audit-body">
						<div>
							<h3>{auditPackage.name}</h3>
							<p class="bitrix-card-text">{auditPackage.text}</p>
						</div>
						<p class="bitrix-price">{auditPackage.price}</p>
					</div>
					<ul>
						{auditPackage.items.map((item) => (
							<li>
								<UiIcon name="check" class="h-4 w-4" />
								<span>{item}</span>
							</li>
						))}
					</ul>
					<a class="ds2-btn ds2-btn-secondary" href="#bitrix-request">
						<span>Заказать аудит</span>
					</a>
				</article>
				{implementationPackages.map((pack) => (
					<article class:list={['ds2-price-card', pack.featured && 'is-featured']}>
						<div class="bitrix-card-top">
							<div class="ds2-service-icon">
								<UiIcon name={pack.icon} class="h-5 w-5" />
							</div>
							<span class="ds2-chip">{pack.tag}</span>
						</div>
						<h3>{pack.name}</h3>
						<p class="bitrix-price">{pack.price}</p>
						<p class="bitrix-card-text">{pack.text}</p>
						<ul>
							{pack.items.map((item) => (
								<li>
									<UiIcon name="check" class="h-4 w-4" />
									<span>{item}</span>
								</li>
							))}
						</ul>
						<a class="ds2-btn ds2-btn-secondary" href="#bitrix-request">
							<span>Рассчитать</span>
						</a>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section ds2-section-soft">
		<div class="ds2-container bitrix-process-grid">
			<div>
				<p class="ds2-kicker">Как проходит внедрение</p>
				<h2>Пять этапов магии интегратора</h2>
				<p>
					Вместо длинной абстрактной схемы показываем управляемый проект: что делаем, что
					проверяем и где фиксируем результат.
				</p>
				<a class="ds2-btn ds2-btn-dark" href="#bitrix-request">
					<span>Собрать состав работ</span>
					<UiIcon name="arrow" class="h-4 w-4" />
				</a>
			</div>
			<ol class="bitrix-timeline" aria-label="Этапы внедрения Bitrix24">
				{steps.map(([icon, title, text], index) => (
					<li class="bitrix-timeline-item">
						<div class="bitrix-timeline-date">
							<span>Этап</span>
							<time>{String(index + 1).padStart(2, '0')}</time>
						</div>
						<div class="bitrix-timeline-track" aria-hidden="true">
							<div class="bitrix-timeline-line"></div>
							<div class="bitrix-timeline-dot">
								<UiIcon name={icon} class="h-4 w-4" />
							</div>
						</div>
						<div class="bitrix-timeline-content">
							<h3>{title}</h3>
							<p>{text}</p>
						</div>
					</li>
				))}
			</ol>
		</div>
	</section>

	<section class="ds2-section bitrix-clients-section">
		<div class="ds2-container">
			<div class="ds2-section-head bitrix-wide-head">
				<div>
					<p class="ds2-kicker">Наши клиенты</p>
					<h2>Нам доверяют компании с работающими процессами продаж</h2>
				</div>
				<p>
					Нам доверяют компании, которым важно не просто купить CRM, а выстроить в ней работающий
					процесс продаж и внутренних коммуникаций.
				</p>
			</div>

			<div class="bitrix-logo-marquee" aria-label="Логотипы клиентов">
				<div class="bitrix-logo-track">
					{[0, 1, 2].map((group) => (
						<div class="bitrix-logo-group" aria-hidden={group === 0 ? 'false' : 'true'}>
							{clientLogos.map((client) => (
								<figure class="bitrix-logo-card">
									<img src={client.src} alt={client.name} loading="lazy" decoding="async" />
								</figure>
							))}
						</div>
					))}
				</div>
			</div>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Услуги в проекте</p>
					<h2>Настраиваем не только CRM</h2>
				</div>
				<p>
					Проект можно собрать из модулей: быстрый запуск продаж, автоматизация внутренних
					процессов, интеграции, миграция данных, обучение и дальнейшее развитие портала.
				</p>
			</div>
			<div class="bitrix-services">
				{services.map((group) => (
					<article class:list={['ds2-service-card', group.title === 'Индивидуальные доработки' ? 'is-accent' : '']}>
						<div class="ds2-service-icon">
							<UiIcon name={group.icon} class="h-5 w-5" />
						</div>
						<h3>{group.title}</h3>
						<ul>
							{group.items.map((item) => (
								<li>
									<UiIcon name="chevron" class="h-4 w-4" />
									<span>{item}</span>
								</li>
							))}
						</ul>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section ds2-section-soft">
		<div class="ds2-container bitrix-version-grid">
			<div class="bitrix-version-copy">
				<p class="ds2-kicker">Облако или коробка</p>
				<h2>Поможем выбрать версию Bitrix24 под задачу</h2>
				<p>
					Не продаем «коробку» там, где достаточно облака. Выбор версии привязываем к
					инфраструктуре, безопасности, интеграциям и будущей нагрузке.
				</p>
			</div>
			<section class="ds2-card bitrix-version-table-card" aria-label="Сравнение облачной и коробочной версии Bitrix24">
				<div class="bitrix-table-wrap">
					<table class="ds2-table">
						<thead>
							<tr>
								<th>Критерий</th>
								<th>Облако</th>
								<th>Коробка</th>
							</tr>
						</thead>
						<tbody>
							{comparison.map(([name, cloud, box]) => (
								<tr>
									<td>{name}</td>
									<td>{cloud}</td>
									<td>{box}</td>
								</tr>
							))}
						</tbody>
					</table>
				</div>
			</section>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
