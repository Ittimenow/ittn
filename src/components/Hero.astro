---
import ConsultationCta from './ConsultationCta.astro';

const metrics = [
	{ value: '150+', label: 'проектов' },
	{ value: '10+', label: 'лет на рынке' },
	{ value: 'CRM / ERP', label: 'интеграции и разработка' },
	{ value: 'Полный цикл', label: 'аудит → запуск → развитие' },
];

const segments = ['B2B', 'Производство', 'Опт', 'Сервис', 'Строительство'];
---

<section class="ds relative isolate overflow-hidden border-b border-neutral-200 dark:border-neutral-800">
	<img
		src="/main-b24-v2.png"
		alt="Рабочее место с CRM-воронкой Битрикс24 на экране"
		class="absolute inset-0 -z-20 h-full w-full object-cover object-[62%_50%]"
		loading="eager"
		decoding="async"
	/>
	<div
		aria-hidden="true"
		class="absolute inset-0 -z-10 bg-[linear-gradient(90deg,rgba(255,255,255,0.97)_0%,rgba(255,255,255,0.9)_48%,rgba(255,255,255,0.2)_100%)] dark:bg-[linear-gradient(90deg,rgba(9,9,11,0.97)_0%,rgba(9,9,11,0.9)_52%,rgba(9,9,11,0.28)_100%)]"
	></div>

	<div class="mx-auto max-w-[1440px] px-6 py-14 sm:py-20 lg:py-24">
		<h1
			class="max-w-4xl text-4xl font-semibold leading-[1.06] text-neutral-950 sm:text-5xl lg:text-6xl dark:text-white"
		>
			Сайты, CRM/ERP и автоматизация процессов для бизнеса, которому нужен порядок
		</h1>

		<p class="mt-6 max-w-2xl text-lg leading-8 text-neutral-700 sm:text-xl dark:text-neutral-300">
			Проектируем и внедряем цифровые решения, которые объединяют сайт,
			продажи, документы, склад, производство и сервис в один управляемый контур.
		</p>

		<ConsultationCta />

		<div class="mt-8 flex flex-wrap gap-2">
			{segments.map((segment) => (
				<span class="rounded-full border border-neutral-200 bg-white/62 px-3 py-1 text-sm text-neutral-700 backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/54 dark:text-neutral-300">
					{segment}
				</span>
			))}
		</div>

		<dl class="mt-10 grid max-w-4xl grid-cols-2 gap-x-6 gap-y-5 border-t border-neutral-200 pt-6 sm:grid-cols-4 dark:border-neutral-800">
			{metrics.map((metric) => (
				<div>
					<dt class="text-sm leading-5 text-neutral-600 dark:text-neutral-400">{metric.label}</dt>
					<dd class="mt-1 text-xl font-semibold text-neutral-950 dark:text-white">{metric.value}</dd>
				</div>
			))}
		</dl>
	</div>
</section>
