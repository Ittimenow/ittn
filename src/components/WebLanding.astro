	},
	{
		name: 'Портал или личный кабинет',
		price: 'от 300 000 ₽',
		tag: 'Роли и процессы',
		icon: 'users',
		text: 'Закрытая или публичная система для клиентов, партнеров, сотрудников и подрядчиков.',
		fit: ['регистрация и авторизация', 'разные роли пользователей', 'документы и файлы', 'заявки и статусы', 'платежи', 'уведомления'],
		includes: ['отчеты', 'история операций', 'интеграция с внутренними системами', 'административная панель'],
		cta: 'Обсудить портал',
	},
	{
		name: 'Индивидуальный веб-сервис',
		price: 'от 600 000 ₽',
		tag: 'MVP и платформы',
		icon: 'workflow',
		text: 'Цифровой продукт с уникальной бизнес-логикой: MVP, агрегатор, SaaS-сервис, внутренняя система или отраслевая платформа.',
		fit: ['анализ идеи', 'ключевые пользовательские сценарии', 'состав первого релиза', 'архитектура', 'запуск без лишнего функционала'],
		includes: ['frontend и backend', 'базы данных', 'API', 'интеграции', 'тестирование и запуск'],
		cta: 'Обсудить веб-сервис',
	},
] as const;

const outcomes = [
	['message', 'Понятное предложение', 'Посетитель быстро понимает, чем занимается компания, какую задачу решает продукт и почему стоит обратиться именно к вам.'],
	['filter', 'Продуманный путь пользователя', 'Структура и интерфейс помогают пройти от первого знакомства до заявки, заказа, оплаты или регистрации.'],
	['database', 'Связь с бизнес-процессами', 'Данные с сайта автоматически поступают в CRM, ERP или другую систему и становятся доступны ответственным сотрудникам.'],
	['bar-chart', 'Основа для продвижения', 'Проектируем логичную структуру страниц, управление метаданными, корректные адреса, адаптивность и скорость загрузки.'],
	['layers', 'Возможность развития', 'Используем компонентный подход, чтобы добавлять новые разделы и функции без полной переделки продукта.'],
	['check', 'Управляемый запуск', 'Разбиваем проект на понятные этапы, показываем промежуточный результат и согласовываем решения до программирования.'],
] as const;

const cases = [
	{
		title: 'Сайт для видео-арт-балета «Сказки сна»',
		href: '/cases/skazki-sna-frontend/',
		image: '/cases/skazki-sna-frontend/img-skazkisna-main-4x3-1.webp',
		task: 'Создать атмосферный лендинг с игровой механикой и возможностью покупки билетов.',
		done: ['адаптировали авторскую визуальную стилистику', 'разработали интерактивные эффекты', 'спроектировали интерфейс покупки билета', 'реализовали генерацию именного видео после покупки'],
		result: ['28,7 тыс. посетителей', '166 сгенерированных видеооткрыток'],
	},
	{
		title: 'Интерактивный сайт строительной компании',
		href: '/cases/berkut-construction-website/',
		image: '/cases/berkut/main-image-skberkut.webp',
		task: 'Создать имиджевый сайт строительной компании с запоминающейся визуальной механикой.',
		done: ['разработали концепцию бесконечно льющегося бетона', 'реализовали реакцию графики на движение курсора', 'добавили динамический счетчик объема бетона', 'создали карту реализованных объектов'],
		result: ['Интерактивный сайт', 'Стоимость проекта 250 000 ₽'],
	},
	{
		title: 'MVP агрегатора строительных отходов',
		href: '/cases/ecocaravan-waste-removal-mvp/',
		image: '/cases/ecocaravan/main-image-ecocaravan.webp',
		task: 'За один месяц разработать первый релиз платформы для заказчиков, перевозчиков и переработчиков.',
		done: ['описали бизнес-процессы', 'сформировали техническое задание', 'разработали сайт и личные кабинеты', 'интегрировали решение с CRM-ERP'],
		result: ['MVP запущен в срок', 'Стоимость проекта 1 200 000 ₽'],
	},
] as const;

const steps = [
	['01', 'message', 'Знакомство и брифинг', 'Обсуждаем бизнес, продукт, аудиторию, текущие процессы, ограничения и ожидаемый результат.', 'Понимание задачи и предварительный состав проекта.'],
	['02', 'filter', 'Аналитика', 'Изучаем материалы, конкурентов, пользовательские сценарии и технические требования.', 'Концепция решения и функциональные требования.'],
	['03', 'layers', 'Структура и прототип', 'Проектируем страницы, навигацию, формы и ключевые действия пользователя.', 'Интерактивный прототип.'],
	['04', 'spark', 'UX/UI-дизайн', 'Создаем визуальную концепцию, дизайн ключевых экранов и систему интерфейсных компонентов.', 'Согласованный дизайн для компьютеров и мобильных устройств.'],
	['05', 'settings', 'Разработка', 'Программируем frontend и backend, подключаем CMS, личные кабинеты, базы данных и внешние системы.', 'Рабочая версия продукта на тестовом контуре.'],
	['06', 'shield', 'Тестирование', 'Проверяем интерфейсы, формы, бизнес-логику, интеграции, адаптивность и основные сценарии.', 'Подготовленный к публикации продукт.'],
	['07', 'rocket', 'Запуск', 'Размещаем проект на сервере, подключаем домен, аналитику и необходимые сервисы.', 'Работающий сайт или сервис.'],
	['08', 'bar-chart', 'Развитие', 'Помогаем обновлять продукт, добавлять функции, развивать интеграции и улучшать сценарии.', 'Решение развивается вместе с бизнесом.'],
] as const;

const projectScope = [
	['Аналитика и проектирование', 'интервью и сбор требований', 'пользовательские сценарии', 'структура сайта', 'прототипирование', 'техническое задание', 'проектирование интеграций'],
	['Контент и дизайн', 'ценностное предложение', 'тексты ключевых блоков', 'UX/UI-дизайн', 'адаптивные версии', 'анимация', 'дизайн-система'],
	['Разработка', 'frontend', 'backend', 'CMS', 'базы данных', 'личные кабинеты', 'API', 'внешние сервисы'],
	['Запуск', 'тестирование', 'перенос на сервер', 'подключение домена', 'аналитика', 'базовая SEO-настройка', 'обучение работе с системой'],
] as const;

const integrations = [
	['CRM и ERP', 'Битрикс24, РосБизнесСофт, ELMA365 и индивидуальные системы.'],
	['Оплата и финансы', 'Платежные сервисы, онлайн-кассы, банки и системы выставления счетов.'],
	['Коммуникации', 'Телефония, электронная почта, мессенджеры, SMS и сервисы рассылок.'],
	['Товары и заказы', 'Складские системы, каталоги, службы доставки и маркетплейсы.'],
	['Аналитика', 'Яндекс Метрика, системы сквозной аналитики и внутренние отчеты.'],
] as const;

const technologies = [
	['Frontend', 'React', 'Astro', 'HTML', 'CSS', 'JavaScript'],
	['Backend', 'NestJS', 'PHP', 'API'],
	['Данные', 'PostgreSQL', 'Prisma'],
	['CMS', 'WordPress', 'Bitrix', 'подходящие системы'],
	['Инфраструктура', 'Docker', 'VPS'],
] as const;

const reasons = [
	['Смотрим шире интерфейса', 'Учитываем, что происходит с заявкой после отправки формы и как сайт взаимодействует с внутренними процессами.'],
	['Проектируем до разработки', 'Сначала проверяем структуру, сценарии и логику, затем переходим к визуалу и программированию.'],
	['Реализуем нестандартную механику', 'Разрабатываем интерактивные интерфейсы, личные кабинеты, расчеты, генераторы, сложные формы и отраслевые сервисы.'],
	['Объединяем компетенции', 'В проекте участвуют аналитик, UX/UI-дизайнер, frontend- и backend-разработчики, тестировщик и менеджер проекта.'],
	['Думаем о дальнейшем развитии', 'Проектируем продукт так, чтобы его можно было расширять и интегрировать с новыми системами.'],
] as const;

const quiz = [
	['Что нужно разработать?', ['Лендинг', 'Корпоративный сайт', 'Интернет-магазин', 'Портал или личный кабинет', 'MVP', 'Веб-сервис', 'Пока не знаю']],
	['Дизайн уже есть?', ['Нужно разработать', 'Есть отдельные материалы', 'Есть готовый дизайн', 'Нужен редизайн текущего сайта']],
	['Нужны ли интеграции?', ['CRM', 'ERP', 'Онлайн-оплата', 'Учетная система', 'Внешние API', 'Пока не знаю']],
	['Ориентировочный бюджет', ['До 300 000 ₽', '300 000-600 000 ₽', '600 000-1 200 000 ₽', 'Более 1 200 000 ₽', 'Нужно оценить']],
] as const;

const faqs = [
	['Сколько стоит разработка сайта?', 'Лендинги начинаются от 150 000 ₽, корпоративные и интерактивные сайты - от 250 000 ₽, интернет-магазины - от 400 000 ₽. Стоимость портала, личного кабинета или индивидуального сервиса зависит от количества ролей, бизнес-логики и интеграций.'],
	['Можно ли начать без технического задания?', 'Да. Для первой встречи достаточно описания задачи, текущих материалов и примеров решений, которые вам нравятся. Требования и техническая часть формируются в процессе аналитики.'],
	['Можно ли доработать существующий сайт?', 'Да. Сначала оцениваем его архитектуру, код, CMS и инфраструктуру. После этого предлагаем доработку либо объясняем, почему новый проект окажется надежнее и экономичнее.'],
	['Вы разрабатываете только дизайн?', 'Можно заказать как полный цикл, так и отдельный этап: аналитику, прототипирование, UX/UI-дизайн, разработку или интеграцию.'],
	['Сможем ли мы сами изменять информацию?', 'Для контентных сайтов предусматривается административная панель. Сотрудники смогут редактировать тексты, изображения, услуги, товары, новости и другие согласованные разделы.'],
	['Можно ли подключить CRM?', 'Да. Можно передавать контакты, заявки, заказы, источники обращений, товары и другие данные, а также запускать автоматические действия после обращения пользователя.'],
	['Работаете ли вы с нестандартными проектами?', 'Да. В портфолио представлены MVP, агрегаторы, финансовые сервисы, интерактивные сайты и проекты, объединяющие сайт с CRM-ERP-системой.'],
	['Что происходит после запуска?', 'Можно продолжить работу в формате технической поддержки и развития: исправлять ошибки, обновлять компоненты, добавлять страницы, улучшать интерфейс и запускать новые функции.'],
] as const;

const faqSchema = {
	'@context': 'https://schema.org',
	'@type': 'FAQPage',
	mainEntity: faqs.map(([question, answer]) => ({
		'@type': 'Question',
		name: question,
		acceptedAnswer: {
			'@type': 'Answer',
			text: answer,
		},
	})),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />
<script is:inline data-b24-form="click/21/8r4fh6" data-skip-moving="true">
	(function(w,d,u){
	var s=d.createElement('script');s.async=true;s.src=u+'?'+(Date.now()/180000|0);
	var h=d.getElementsByTagName('script')[0];h.parentNode.insertBefore(s,h);
	})(window,document,'https://cdn-ru.bitrix24.ru/b27699562/crm/form/loader_21.js');
</script>
<script>
	function bindWebB24Buttons() {
		document.querySelectorAll('[data-web-b24-form]').forEach((button) => {
			if (button instanceof HTMLElement) {
				button.addEventListener('click', (event) => event.preventDefault());
			}
		});
	}

	bindWebB24Buttons();
	document.addEventListener('astro:page-load', bindWebB24Buttons);
</script>

<div class="ds web-landing">
	<a class:list={['web-sticky-cta', b24ButtonClass]} href="#" data-web-b24-form>
		<span>Обсудить проект</span>
		<UiIcon name="arrow" class="h-4 w-4" />
	</a>

	<section class="relative isolate overflow-hidden border-b border-neutral-200 bg-neutral-50 dark:border-neutral-800 dark:bg-neutral-950">
		<div class="absolute inset-0 -z-10 bg-[linear-gradient(115deg,rgba(255,255,255,0.98)_0%,rgba(246,247,251,0.94)_45%,rgba(95,102,255,0.14)_100%)] dark:bg-[linear-gradient(115deg,rgba(9,9,11,1)_0%,rgba(17,17,22,0.96)_52%,rgba(95,102,255,0.2)_100%)]"></div>
		<div class="mx-auto grid min-h-[calc(100vh-96px)] max-w-[1440px] items-center gap-12 px-6 py-16 sm:py-20 lg:grid-cols-[minmax(0,1fr)_minmax(420px,560px)] lg:py-24">
			<div>
				<nav class="mb-8 flex flex-wrap items-center gap-2 text-sm text-neutral-500 dark:text-neutral-400" aria-label="Хлебные крошки">
					<a href="/services/" class="hover:text-indigo-600 dark:hover:text-indigo-300">Все услуги</a>
					<UiIcon name="chevron" class="h-3.5 w-3.5" />
					<span>Разработка сайтов и веб-сервисов</span>
				</nav>
				<p class="ds-kicker border border-indigo-200 bg-white/72 text-indigo-700 backdrop-blur dark:border-indigo-500/30 dark:bg-neutral-950/60 dark:text-indigo-300">
					Разработка сайтов и веб-сервисов для бизнеса
				</p>
				<h1 transition:name="service-web" class="mt-4 max-w-5xl text-4xl font-semibold leading-[1.04] text-neutral-950 sm:text-5xl lg:text-6xl dark:text-white">
					Создаем сайты и цифровые сервисы, которые помогают продавать, автоматизировать и масштабировать бизнес
				</h1>
				<p class="mt-6 max-w-3xl text-lg leading-8 text-neutral-700 sm:text-xl dark:text-neutral-300">
					Проектируем интерфейсы, разрабатываем дизайн, программируем и интегрируем решение с CRM, ERP, платежными системами и другими сервисами вашей компании.
				</p>
				<p class="mt-4 max-w-3xl text-lg leading-8 text-neutral-700 dark:text-neutral-300">
