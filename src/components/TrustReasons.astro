---
const reasons = [
	{
		title: 'Объединяем разработку и автоматизацию',
		text: 'Не нужно искать отдельно студию, интегратора, разработчиков и поддержку.',
	},
	{
		title: 'Работаем от бизнес-процесса',
		text: 'Сначала разбираем задачу, затем проектируем решение и только потом внедряем.',
	},
	{
		title: 'Подбираем платформу под модель бизнеса',
		text: 'Bitrix24, РосБизнесСофт, ЭЛМА или кастомная разработка выбираются по задаче.',
	},
	{
		title: 'Закрываем полный цикл',
		text: 'Аудит, проектирование, разработка, интеграции, запуск, обучение и развитие.',
	},
	{
		title: 'Работаем со сложными задачами',
		text: 'Кейсы охватывают страхование, банк, девелопмент, ритейл и промышленность.',
	},
];
---

<section class="bg-neutral-50 py-16 dark:bg-neutral-950 sm:py-24">
	<div class="mx-auto max-w-[1440px] px-6">
		<div class="mb-10 max-w-3xl">
			<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Почему нам доверяют</p>
			<h2 class="mt-2 text-3xl font-semibold leading-tight sm:text-4xl">
				К нам приходят не за ещё одним подрядчиком, а за системой
			</h2>
		</div>

		<div class="grid gap-4 md:grid-cols-2 lg:grid-cols-5">
			{reasons.map((reason) => (
				<article class="rounded-2xl border border-neutral-200 bg-white p-5 dark:border-neutral-800 dark:bg-neutral-900/40">
					<h3 class="font-semibold leading-6">{reason.title}</h3>
					<p class="mt-3 text-sm leading-6 text-neutral-600 dark:text-neutral-400">{reason.text}</p>
				</article>
			))}
		</div>
	</div>
</section>
