---
const interests = [
	'Нужен аудит',
	'Нужен сайт / сервис',
	'Нужна CRM / ERP',
	'Нужны интеграции',
	'Нужна поддержка',
];
---

<section id="consultation" class="mx-auto max-w-[1440px] px-6 py-16 sm:py-24">
	<div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900/40">
		<div class="grid gap-10 p-8 sm:p-12 md:grid-cols-2">
			<div>
				<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Консультация</p>
				<h2 class="mt-2 text-3xl font-semibold leading-tight sm:text-4xl">Обсудим, с чего начать</h2>
				<p class="mt-4 text-neutral-700 dark:text-neutral-300">
					Поможем понять, что нужно на старте: сайт, CRM, ERP, интеграции
					или аудит процессов.
				</p>
				<dl class="mt-6 space-y-3 text-sm">
					<div class="flex gap-3">
						<dt class="w-20 text-neutral-500">Телефон</dt>
						<dd>
							<a href="tel:+74951335888" class="font-medium hover:text-indigo-600 dark:hover:text-indigo-400">
								+7 (495) 133-58-88
							</a>
						</dd>
					</div>
					<div class="flex gap-3">
						<dt class="w-20 text-neutral-500">Email</dt>
						<dd>
							<a href="mailto:hello@ittimenow.com" class="font-medium hover:text-indigo-600 dark:hover:text-indigo-400">
								hello@ittimenow.com
							</a>
						</dd>
					</div>
				</dl>
			</div>

			<form
				class="grid gap-3 rounded-2xl border border-neutral-200 bg-neutral-50 p-6 dark:border-neutral-800 dark:bg-neutral-950"
				method="post"
				action="#"
			>
				<label class="grid gap-1.5 text-sm">
					<span class="text-neutral-700 dark:text-neutral-300">Имя</span>
					<input
						required
						type="text"
						name="name"
						class="rounded-md border border-neutral-200 bg-white px-3 py-2 text-sm outline-none focus:border-indigo-500 dark:border-neutral-800 dark:bg-neutral-900"
					/>
				</label>
				<label class="grid gap-1.5 text-sm">
					<span class="text-neutral-700 dark:text-neutral-300">Компания</span>
					<input
						type="text"
						name="company"
						class="rounded-md border border-neutral-200 bg-white px-3 py-2 text-sm outline-none focus:border-indigo-500 dark:border-neutral-800 dark:bg-neutral-900"
					/>
				</label>
				<label class="grid gap-1.5 text-sm">
					<span class="text-neutral-700 dark:text-neutral-300">Телефон или email</span>
					<input
						required
						type="text"
						name="contact"
						class="rounded-md border border-neutral-200 bg-white px-3 py-2 text-sm outline-none focus:border-indigo-500 dark:border-neutral-800 dark:bg-neutral-900"
					/>
				</label>
				<label class="grid gap-1.5 text-sm">
					<span class="text-neutral-700 dark:text-neutral-300">Коротко о задаче</span>
					<textarea
						name="message"
						rows="4"
						class="rounded-md border border-neutral-200 bg-white px-3 py-2 text-sm outline-none focus:border-indigo-500 dark:border-neutral-800 dark:bg-neutral-900"
					></textarea>
				</label>
				<fieldset class="grid gap-2">
					<legend class="text-sm text-neutral-700 dark:text-neutral-300">Что актуально</legend>
					<div class="flex flex-wrap gap-2">
						{interests.map((interest) => (
							<label class="inline-flex items-center gap-2 rounded-full border border-neutral-200 bg-white px-3 py-1.5 text-sm text-neutral-700 dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300">
								<input type="checkbox" name="interest" value={interest} class="h-4 w-4 rounded border-neutral-300 text-indigo-600" />
								<span>{interest}</span>
							</label>
						))}
					</div>
				</fieldset>
				<button
					type="submit"
					class="mt-2 rounded-md bg-neutral-900 px-5 py-2.5 text-sm font-medium text-white transition hover:bg-neutral-700 dark:bg-white dark:text-neutral-900 dark:hover:bg-neutral-200"
				>
					Отправить заявку
				</button>
				<p class="text-xs text-neutral-500">
					Свяжемся в рабочее время, обсудим задачу, предложим варианты и следующий шаг.
				</p>
			</form>
		</div>
	</div>
</section>
