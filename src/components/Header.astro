---
import ThemeToggle from './ThemeToggle.astro';

interface Props {
	variant?: 'default' | 'glass';
}

const { variant = 'glass' } = Astro.props;
const isGlass = variant === 'glass';

const services = {
	'Разработка': [{ title: 'Сайты и сервисы', href: '/services/web' }],
	'Автоматизация': [
		{ title: 'Битрикс24', href: '/services/bitrix24' },
		{ title: 'РосБизнесСофт', href: '/services/rbs' },
		{ title: 'ЭЛМА', href: '/services/elma' },
	],
	'Дополнительно': [
		{ title: 'Искусственный интеллект', href: '/services/ai' },
		{ title: 'Сопровождение IT-проектов', href: '/services/support' },
	],
};
---

<header
	class:list={[
		isGlass
			? 'sticky top-3 z-40 px-3 pt-3 sm:top-4 sm:px-6 sm:pt-4'
			: 'sticky top-0 z-40 border-b border-neutral-200 bg-white/80 backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/80',
	]}
>
	<div
		class:list={[
			'relative mx-auto grid w-full max-w-[1440px] grid-cols-[minmax(0,1fr)_auto] items-center gap-4 overflow-visible md:grid-cols-[auto_minmax(0,1fr)_auto] md:gap-6',
			isGlass
				? 'rounded-2xl border border-white/45 px-4 py-3 shadow-[0_18px_60px_rgba(15,23,42,0.16),inset_0_1px_0_rgba(255,255,255,0.75)] ring-1 ring-black/[0.03] sm:px-5 dark:border-white/10 dark:shadow-[0_18px_60px_rgba(0,0,0,0.42),inset_0_1px_0_rgba(255,255,255,0.12)] dark:ring-white/[0.04]'
				: 'px-6 py-4',
		]}
	>
		{isGlass && (
			<div
				aria-hidden="true"
				class="pointer-events-none absolute inset-0 rounded-2xl bg-white/58 backdrop-blur-2xl backdrop-saturate-150 dark:bg-neutral-950/46"
			></div>
		)}

		<a href="/" class="relative z-10 flex min-w-0 items-center gap-3 justify-self-start" aria-label="IT TIME NOW">
			<img
				src="https://ittimenow.com/wp-content/uploads/2022/03/%D0%A0%D0%B5%D1%81%D1%83%D1%80%D1%81-1-1.webp"
				alt="IT TIME NOW"
				class="h-[26px] w-auto shrink-0 dark:brightness-0 dark:invert"
				loading="eager"
				decoding="async"
			/>
			<span class="hidden translate-y-px leading-tight text-neutral-900 sm:block dark:text-neutral-100">
				<span class="block text-[11px] font-normal">Цифровые системы</span>
				<span class="block text-[11px] font-normal">эффективного бизнеса</span>
			</span>
		</a>

		<nav class="relative z-10 hidden items-center justify-self-center text-sm md:flex">
			<div class="group relative">
				<a
					href="/services"
					class="flex items-center gap-1 px-3 py-2 text-neutral-700 transition hover:text-[#232BFF] focus-visible:text-[#232BFF] group-hover:text-[#232BFF] dark:text-neutral-300 dark:hover:text-[#6C7CFF] dark:focus-visible:text-[#6C7CFF] dark:group-hover:text-[#6C7CFF]"
					aria-haspopup="true"
				>
					Услуги
					<svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M2 4l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</a>
				<div
					class="invisible pointer-events-none absolute top-full left-1/2 z-50 w-[640px] max-w-[calc(100vw-2rem)] -translate-x-1/2 pt-3 group-hover:pointer-events-auto group-hover:visible group-focus-within:pointer-events-auto group-focus-within:visible"
				>
					<div
						class:list={[
							'relative overflow-hidden',
							isGlass
								? 'rounded-2xl border border-white/45 bg-white/42 shadow-[0_18px_60px_rgba(15,23,42,0.16),inset_0_1px_0_rgba(255,255,255,0.75)] ring-1 ring-black/[0.03] backdrop-blur-[64px] backdrop-saturate-200 dark:border-white/10 dark:bg-neutral-950/36 dark:shadow-[0_18px_60px_rgba(0,0,0,0.42),inset_0_1px_0_rgba(255,255,255,0.12)] dark:ring-white/[0.04]'
								: 'rounded-xl border border-neutral-200 bg-white shadow-xl dark:border-neutral-800 dark:bg-neutral-900',
						]}
					>
						<div class="relative z-10 grid grid-cols-3 gap-6 p-6">
							{Object.entries(services).map(([group, items]) => (
								<div>
									<p class="mb-3 text-xs font-semibold uppercase tracking-wider text-neutral-500">
										{group}
									</p>
									<ul class="space-y-2">
										{items.map((item) => (
											<li>
												<a
													href={item.href}
													class="block text-sm text-neutral-700 transition hover:text-indigo-600 dark:text-neutral-300 dark:hover:text-indigo-400"
												>
													{item.title}
												</a>
											</li>
										))}
									</ul>
								</div>
							))}
						</div>
					</div>
				</div>
			</div>

			<a href="/cases" class="px-3 py-2 text-neutral-700 transition hover:text-[#232BFF] focus-visible:text-[#232BFF] dark:text-neutral-300 dark:hover:text-[#6C7CFF] dark:focus-visible:text-[#6C7CFF]">
				Кейсы
			</a>
			<a href="/posts" class="px-3 py-2 text-neutral-700 transition hover:text-[#232BFF] focus-visible:text-[#232BFF] dark:text-neutral-300 dark:hover:text-[#6C7CFF] dark:focus-visible:text-[#6C7CFF]">
				Блог
			</a>
			<a href="/about" class="px-3 py-2 text-neutral-700 transition hover:text-[#232BFF] focus-visible:text-[#232BFF] dark:text-neutral-300 dark:hover:text-[#6C7CFF] dark:focus-visible:text-[#6C7CFF]">
				О нас
			</a>
		</nav>

		<div class="relative z-10 col-start-2 flex items-center gap-3 justify-self-end md:col-start-3">
			<a
				href="tel:+74951335888"
				class="hidden text-sm font-medium text-neutral-700 transition hover:text-neutral-900 lg:inline dark:text-neutral-300 dark:hover:text-neutral-100"
			>
				+7 (495) 133-58-88
			</a>
			<ThemeToggle />
			<button
				id="mobile-menu-toggle"
				type="button"
				aria-label="Меню"
				class:list={[
					'inline-flex h-9 w-9 items-center justify-center text-neutral-700 md:hidden dark:text-neutral-300',
					isGlass
						? 'rounded-xl border border-white/50 bg-white/45 shadow-[inset_0_1px_0_rgba(255,255,255,0.7)] backdrop-blur-xl dark:border-white/10 dark:bg-white/5'
						: 'rounded-md border border-neutral-200 bg-white dark:border-neutral-800 dark:bg-neutral-900',
				]}
			>
				<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<path d="M3 6h18M3 12h18M3 18h18"></path>
				</svg>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class:list={[
			'hidden md:hidden',
			isGlass
				? 'mx-auto mt-2 w-full max-w-[1440px] rounded-2xl border border-white/45 bg-white/68 px-4 py-4 shadow-[0_18px_50px_rgba(15,23,42,0.14),inset_0_1px_0_rgba(255,255,255,0.72)] backdrop-blur-2xl backdrop-saturate-150 dark:border-white/10 dark:bg-neutral-950/72'
				: 'border-t border-neutral-200 bg-white px-6 py-4 dark:border-neutral-800 dark:bg-neutral-950',
		]}
	>
		<nav class="flex flex-col gap-3 text-sm">
			<a href="/services" class="font-medium">Услуги</a>
			{Object.entries(services).map(([group, items]) => (
				<div class="ml-3 border-l border-neutral-200 pl-3 dark:border-neutral-800">
					<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">{group}</p>
					<ul class="mt-1 space-y-1">
						{items.map((item) => (
							<li><a href={item.href} class="text-neutral-600 dark:text-neutral-400">{item.title}</a></li>
						))}
					</ul>
				</div>
			))}
			<a href="/cases">Кейсы</a>
			<a href="/posts">Блог</a>
			<a href="/about">О нас</a>
		</nav>
	</div>
</header>

<script>
	function bindMobileMenu() {
		const btn = document.getElementById('mobile-menu-toggle');
		const menu = document.getElementById('mobile-menu');
		if (!btn || !menu || btn.dataset.bound) return;
		btn.dataset.bound = '1';
		btn.addEventListener('click', () => menu.classList.toggle('hidden'));
	}
	bindMobileMenu();
	document.addEventListener('astro:page-load', bindMobileMenu);
</script>
