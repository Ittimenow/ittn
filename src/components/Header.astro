---
import ThemeToggle from './ThemeToggle.astro';

const services = {
	'Разработка': [{ title: 'Сайты и сервисы', href: '/services/web' }],
	'Автоматизация': [
		{ title: 'Битрикс24', href: '/services/bitrix24' },
		{ title: 'РосБизнесСофт', href: '/services/rbs' },
		{ title: 'ЭЛМА', href: '/services/elma' },
	],
	'Дополнительно': [
		{ title: 'Искусственный интеллект', href: '/services/ai' },
		{ title: 'Сопровождение IT-проектов', href: '/services/support' },
	],
};
---

<header
	class="sticky top-0 z-40 border-b border-neutral-200 bg-white/80 backdrop-blur dark:border-neutral-800 dark:bg-neutral-950/80"
>
	<div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
		<a href="/" class="flex items-center gap-2 text-lg font-semibold tracking-tight">
			<span
				class="inline-flex h-8 w-8 items-center justify-center rounded-md bg-gradient-to-br from-indigo-500 to-fuchsia-500 text-sm font-black text-white"
			>
				IT
			</span>
			<span>ittimenow</span>
		</a>

		<nav class="hidden items-center gap-6 text-sm md:flex">
			<div class="group relative">
				<button
					type="button"
					class="flex items-center gap-1 text-neutral-700 transition hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-neutral-100"
					aria-haspopup="true"
				>
					Услуги
					<svg class="h-3 w-3" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2">
						<path d="M2 4l4 4 4-4" stroke-linecap="round" stroke-linejoin="round"></path>
					</svg>
				</button>
				<div
					class="invisible absolute top-full left-1/2 z-50 mt-2 grid w-[640px] -translate-x-1/2 grid-cols-3 gap-6 rounded-xl border border-neutral-200 bg-white p-6 opacity-0 shadow-xl transition group-hover:visible group-hover:opacity-100 dark:border-neutral-800 dark:bg-neutral-900"
				>
					{Object.entries(services).map(([group, items]) => (
						<div>
							<p class="mb-3 text-xs font-semibold uppercase tracking-wider text-neutral-500">
								{group}
							</p>
							<ul class="space-y-2">
								{items.map((item) => (
									<li>
										<a
											href={item.href}
											class="block text-sm text-neutral-700 transition hover:text-indigo-600 dark:text-neutral-300 dark:hover:text-indigo-400"
										>
											{item.title}
										</a>
									</li>
								))}
							</ul>
						</div>
					))}
				</div>
			</div>

			<a href="/cases" class="text-neutral-700 transition hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-neutral-100">
				Кейсы
			</a>
			<a href="/posts" class="text-neutral-700 transition hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-neutral-100">
				Блог
			</a>
			<a href="/about" class="text-neutral-700 transition hover:text-neutral-900 dark:text-neutral-300 dark:hover:text-neutral-100">
				О нас
			</a>
		</nav>

		<div class="flex items-center gap-3">
			<a
				href="tel:+74951335888"
				class="hidden text-sm font-medium text-neutral-700 transition hover:text-neutral-900 lg:inline dark:text-neutral-300 dark:hover:text-neutral-100"
			>
				+7 (495) 133-58-88
			</a>
			<ThemeToggle />
			<button
				id="mobile-menu-toggle"
				type="button"
				aria-label="Меню"
				class="inline-flex h-9 w-9 items-center justify-center rounded-md border border-neutral-200 bg-white text-neutral-700 md:hidden dark:border-neutral-800 dark:bg-neutral-900 dark:text-neutral-300"
			>
				<svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
					<path d="M3 6h18M3 12h18M3 18h18"></path>
				</svg>
			</button>
		</div>
	</div>

	<div
		id="mobile-menu"
		class="hidden border-t border-neutral-200 bg-white px-6 py-4 md:hidden dark:border-neutral-800 dark:bg-neutral-950"
	>
		<nav class="flex flex-col gap-3 text-sm">
			<a href="/services" class="font-medium">Услуги</a>
			{Object.entries(services).map(([group, items]) => (
				<div class="ml-3 border-l border-neutral-200 pl-3 dark:border-neutral-800">
					<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">{group}</p>
					<ul class="mt-1 space-y-1">
						{items.map((item) => (
							<li><a href={item.href} class="text-neutral-600 dark:text-neutral-400">{item.title}</a></li>
						))}
					</ul>
				</div>
			))}
			<a href="/cases">Кейсы</a>
			<a href="/posts">Блог</a>
			<a href="/about">О нас</a>
		</nav>
	</div>
</header>

<script>
	function bindMobileMenu() {
		const btn = document.getElementById('mobile-menu-toggle');
		const menu = document.getElementById('mobile-menu');
		if (!btn || !menu || btn.dataset.bound) return;
		btn.dataset.bound = '1';
		btn.addEventListener('click', () => menu.classList.toggle('hidden'));
	}
	bindMobileMenu();
	document.addEventListener('astro:page-load', bindMobileMenu);
</script>
