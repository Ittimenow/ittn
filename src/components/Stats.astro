---
const stats = [
	{ value: '150+', label: 'реализованных проектов' },
	{ value: '10+', label: 'лет на рынке' },
	{ value: '40+', label: 'специалистов' },
	{ value: '24/7', label: 'поддержка' },
];
---

<section class="mx-auto max-w-[1440px] px-6 py-16 sm:py-24">
	<dl class="grid grid-cols-2 gap-px overflow-hidden rounded-2xl border border-neutral-200 bg-neutral-200 sm:grid-cols-4 dark:border-neutral-800 dark:bg-neutral-800">
		{stats.map((s) => (
			<div class="flex flex-col items-start gap-2 bg-white p-6 dark:bg-neutral-950">
				<dt class="text-xs uppercase tracking-wider text-neutral-500">{s.label}</dt>
				<dd class="text-3xl font-semibold sm:text-4xl">{s.value}</dd>
			</div>
		))}
	</dl>
</section>
