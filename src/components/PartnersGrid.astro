---
const groups = [
	{ title: 'Вендоры', items: ['Битрикс24', 'РосБизнесСофт', 'ЭЛМА', '1С'] },
	{ title: 'Телефония', items: ['Mango Office', 'Sipuni', 'UIS', 'Zadarma'] },
	{ title: 'Мессенджеры', items: ['WhatsApp Business', 'Telegram', 'VK', 'Wazzup'] },
	{ title: 'Рассылки', items: ['Unisender', 'SendPulse', 'Mindbox'] },
	{ title: 'Хостинг', items: ['Yandex Cloud', 'Selectel', 'Cloud.ru', 'Timeweb'] },
];
---

<section class="mx-auto max-w-[1440px] px-6 py-16 sm:py-24">
	<div class="mb-8">
		<p class="text-sm font-medium text-indigo-600 dark:text-indigo-400">Партнёры</p>
		<h2 class="mt-1 text-3xl font-semibold tracking-tight sm:text-4xl">Экосистема интеграций</h2>
	</div>
	<div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-5">
		{groups.map((g) => (
			<div class="rounded-2xl border border-neutral-200 bg-white p-5 dark:border-neutral-800 dark:bg-neutral-900/40">
				<p class="text-xs font-semibold uppercase tracking-wider text-neutral-500">{g.title}</p>
				<ul class="mt-3 space-y-1.5 text-sm text-neutral-700 dark:text-neutral-300">
					{g.items.map((i) => <li>{i}</li>)}
				</ul>
			</div>
		))}
	</div>
</section>
