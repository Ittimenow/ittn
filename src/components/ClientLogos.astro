---
const clients = [
	{ name: 'Perola Sky', src: '/clients/client-perola.webp' },
	{ name: 'William Grant & Sons Ltd.', src: '/clients/client-wgs.webp' },
	{ name: 'Альфа-страхование', src: '/clients/client-alfa.webp' },
	{ name: 'Донстрой', src: '/clients/client-donstroy.webp' },
	{ name: 'Amaffi Parfume House', src: '/clients/client-amaffi.webp' },
	{ name: 'Americhip', src: '/clients/client-americhip.webp' },
	{ name: 'Бобровский сыродельный завод', src: '/clients/client-bobrovskiycir.webp' },
	{
		name: 'Фонд содействия развитию детского и ветеранского волейбола имени В. В. Жукова',
		src: '/clients/client-vfv.webp',
	},
	{ name: 'Росконцерт', src: '/clients/client-rosconcert.webp' },
];
---

<section class="client-logos mx-auto max-w-[1440px] px-6 py-16 sm:py-24">
	<div class="mb-8 max-w-3xl">
		<h2 class="text-3xl font-semibold leading-tight sm:text-4xl">Компании, с которыми уже работали</h2>
	</div>
	<div class="logo-marquee" aria-label="Логотипы клиентов">
		<div class="logo-track">
			{[0, 1, 2].map((group) => (
				<div class="logo-group" aria-hidden={group === 0 ? 'false' : 'true'}>
					{clients.map((client) => (
						<figure class="logo-card">
							<img src={client.src} alt={client.name} loading="lazy" decoding="async" />
						</figure>
					))}
				</div>
			))}
		</div>
	</div>
</section>

<style>
	.client-logos {
		overflow: hidden;
	}

	.logo-marquee {
		position: relative;
		overflow: hidden;
		mask-image: linear-gradient(90deg, transparent, #000 8%, #000 92%, transparent);
	}

	.logo-track {
		display: flex;
		width: max-content;
		will-change: transform;
		animation: logo-marquee 18s linear infinite;
	}

	.logo-group {
		display: flex;
		flex: 0 0 auto;
		gap: 40px;
		padding-right: 40px;
	}

	.logo-card {
		display: grid;
		width: clamp(220px, 24vw, 320px);
		min-height: 130px;
		place-items: center;
		border: 0;
		background: transparent;
		padding: 10px;
	}

	.logo-card img {
		max-width: 100%;
		max-height: 96px;
		object-fit: contain;
	}

	@keyframes logo-marquee {
		from {
			transform: translate3d(0, 0, 0);
		}

		to {
			transform: translate3d(-33.333%, 0, 0);
		}
	}

	@media (prefers-reduced-motion: reduce) {
		.logo-track {
			animation: none;
		}

		.logo-marquee {
			overflow-x: auto;
			mask-image: none;
		}
	}
</style>
