---
import UiIcon from './UiIcon.astro';

const heroBenefits = [
	'единая база клиентов и\u00A0сделок',
	'продажи связаны со\u00A0складом',
	'меньше ручного контроля',
	'документы по\u00A0шаблонам',
	'интеграции с\u00A01С\u00A0и\u00A0сайтом',
	'понятные KPI\u00A0и\u00A0отчеты',
] as const;

const fitItems = [
	'B2B-продажи с\u00A0долгим циклом сделки',
	'оптовая или\u00A0дистрибьюторская компания',
	'производство с\u00A0заказами, материалами и\u00A0отгрузками',
	'складской учет, закупки и\u00A0остатки',
	'сервисный центр или\u00A0выездные инженеры',
	'строительная, проектная или\u00A0монтажная компания',
	'несколько отделов с\u00A0потерями задач и\u00A0документов',
	'1С, сайт, телефония и\u00A0почта, которые нужно связать',
] as const;

const tasks = [
	{
		icon: 'briefcase',
		title: 'Наводим порядок в\u00A0продажах',
		text: 'Настраиваем клиентскую базу, сделки, воронки, задачи, напоминания, контроль звонков и\u00A0писем.',
	},
	{
		icon: 'workflow',
		title: 'Связываем CRM\u00A0и\u00A0ERP-логику',
		text: 'Соединяем заказы клиентов, номенклатуру, остатки, закупки, производство, отгрузки и\u00A0документы.',
	},
	{
		icon: 'layers',
		title: 'Настраиваем интеграции',
		text: 'Подключаем сайт, формы, почту, телефонию, мессенджеры, 1С, API\u00A0и\u00A0внешние сервисы.',
	},
	{
		icon: 'database',
		title: 'Переносим данные',
		text: 'Мигрируем клиентов, компании, контакты, товары, сделки, историю и\u00A0остатки из\u00A0Excel, 1С\u00A0или\u00A0старой CRM.',
	},
	{
		icon: 'file',
		title: 'Автоматизируем документы',
		text: 'Создаем шаблоны КП, договоров, счетов, актов, УПД\u00A0и\u00A0писем, чтобы сотрудники не\u00A0копировали данные вручную.',
	},
	{
		icon: 'users',
		title: 'Внедряем в\u00A0ежедневную работу',
		text: 'Обучаем команду, готовим инструкции, регламенты, KPI\u00A0и\u00A0правила контроля качества заполнения CRM.',
	},
] as const;

const benefits = [
	['Единая система', 'Клиенты, сделки, задачи, документы, склад, производство и\u00A0сервис работают в\u00A0одном пространстве.'],
	['Меньше ручной работы', 'Заявки попадают в\u00A0CRM, письма и\u00A0звонки привязываются к\u00A0клиенту, документы формируются по\u00A0шаблонам.'],
	['Контроль продаж', 'Руководитель видит воронки, этапы сделок, просрочки, активность менеджеров и\u00A0прогноз продаж.'],
	['Быстрее обработка заказов', 'Менеджеры, склад и\u00A0производство работают по\u00A0единому процессу, без\u00A0передачи данных в\u00A0чатах и\u00A0Excel.'],
	['Меньше ошибок', 'Регламенты, поля, роли и\u00A0автоматизация снижают риск забытых задач и\u00A0неверных данных в\u00A0заказах.'],
	['Рост вместе с\u00A0бизнесом', 'РосБизнесСофт можно дорабатывать под\u00A0отрасль, подразделения, роли, отчеты и\u00A0нестандартные процессы.'],
] as const;

const packages = [
	{
		name: 'Предпроектное обследование',
		price: 'от\u00A050\u00A0000\u00A0₽',
		icon: 'filter',
		tag: 'План',
		text: 'Когда нужно описать процессы, выбрать модули и\u00A0получить понятную дорожную карту внедрения.',
		items: ['интервью с\u00A0руководителями', 'карта процессов и\u00A0проблем', 'состав модулей и\u00A0интеграций', 'план работ и\u00A0смета'],
	},
	{
		name: 'Первичное внедрение',
		price: '80\u00A0000\u00A0₽',
		icon: 'rocket',
		tag: 'Старт',
		text: 'Быстрый запуск CRM\u00A0с\u00A0базовой настройкой для\u00A0продаж, пользователей, прав и\u00A0рабочего сценария.',
		items: ['структура компании', 'пользователи, роли и\u00A0права', 'карточки и\u00A0воронки', 'базовое обучение'],
	},
	{
		name: 'Проектное внедрение',
		price: 'от\u00A0300\u00A0000\u00A0₽',
		icon: 'workflow',
		tag: 'Комплексно',
		featured: true,
		text: 'Настройка под\u00A0процессы компании: CRM, ERP-модули, интеграции, перенос данных, обучение и\u00A0адаптация.',
		items: ['аудит и\u00A0ТЗ', 'CRM\u00A0и\u00A0ERP-модули', '1С, сайт, телефония и\u00A0API', 'миграция, запуск и\u00A0сопровождение'],
	},
] as const;

const services = [
	{
		title: 'Предпроектное обследование',
		icon: 'filter',
		items: ['интервью с\u00A0руководителями и\u00A0ключевыми сотрудниками', 'описание текущих процессов', 'карта внедрения и\u00A0список настроек'],
	},
	{
		title: 'Настройка CRM\u00A0и\u00A0ERP-модулей',
		icon: 'settings',
		items: ['карточки клиентов, сделок, заказов и\u00A0товаров', 'склады, документы, проекты и\u00A0сервисные обращения', 'производственные процессы'],
	},
	{
		title: 'Интеграция с\u00A01С',
		icon: 'database',
		items: ['контрагенты, товары и\u00A0счета', 'заказы, оплаты и\u00A0остатки', 'правила обмена под\u00A0вашу конфигурацию'],
	},
	{
		title: 'Интеграции с\u00A0каналами',
		icon: 'phone',
		items: ['заявки с\u00A0сайта и\u00A0лендингов', 'телефония, почта и\u00A0мессенджеры', 'API\u00A0и\u00A0внешние сервисы'],
	},
	{
		title: 'Миграция данных',
		icon: 'layers',
		items: ['клиенты, контакты и\u00A0компании', 'сделки, товары и\u00A0остатки', 'документы и\u00A0история взаимодействий'],
	},
	{
		title: 'Отчеты, обучение и\u00A0поддержка',
		icon: 'bar-chart',
		items: ['отчеты по\u00A0продажам, складу, сервису и\u00A0KPI', 'инструкции и\u00A0обучение пользователей', 'помощь после запуска'],
	},
] as const;

const steps = [
	['filter', 'Аудит', 'Фиксируем цели, процессы, роли, данные и\u00A0точки потерь.'],
	['file', 'Техническое задание', 'Описываем модули, карточки, поля, документы, интеграции и\u00A0критерии готовности.'],
	['settings', 'Настройка', 'Конфигурируем CRM/ERP, права, воронки, рабочие столы, документы и\u00A0отчеты.'],
	['layers', 'Интеграции', 'Связываем РосБизнесСофт с\u00A01С, сайтом, телефонией, почтой, API\u00A0и\u00A0внешними сервисами.'],
	['database', 'Перенос данных', 'Импортируем и\u00A0проверяем клиентов, товары, сделки, остатки, документы и\u00A0историю.'],
	['users', 'Обучение', 'Показываем сотрудникам рабочие сценарии и\u00A0закрепляем регламенты.'],
	['rocket', 'Запуск и\u00A0развитие', 'Запускаем систему, контролируем первые результаты и\u00A0донастраиваем процессы.'],
] as const;

const clientLogos = [
	{ name: 'Perola Sky', src: '/clients/client-perola.png' },
	{ name: 'William Grant & Sons Ltd.', src: '/clients/client-wgs.png' },
	{ name: 'Альфа-страхование', src: '/clients/client-alfa.png' },
	{ name: 'Донстрой', src: '/clients/client-donstroy.png' },
] as const;

const outcomes = [
	['Стало понятно, где\u00A0сделки', 'После настройки воронок, задач и\u00A0отчетов руководитель видит загрузку, просрочки и\u00A0прогноз продаж.'],
	['Документы готовятся быстрее', 'Шаблоны счетов, договоров и\u00A0КП\u00A0уменьшают ручной ввод и\u00A0количество ошибок.'],
	['Заявки не\u00A0теряются', 'Формы сайта, почта и\u00A0телефония связаны с\u00A0CRM, поэтому каждое обращение попадает в\u00A0работу.'],
] as const;

const faqs = [
	['Сколько стоит внедрение РосБизнесСофт?', 'Быстрое внедрение в\u00A0IT\u00A0TIME\u00A0NOW стоит от\u00A080\u00A0000\u00A0₽. Проектное внедрение - от\u00A0300\u00A0000\u00A0₽. Итог зависит от\u00A0количества пользователей, модулей, интеграций, объема данных и\u00A0сложности процессов.'],
	['Чем РосБизнесСофт отличается от\u00A0обычной CRM?', 'Обычная CRM чаще закрывает продажи, задачи и\u00A0клиентскую базу. РосБизнесСофт может работать как\u00A0CRM/ERP-система: продажи, склад, закупки, производство, сервис, документы, отчеты и\u00A0интеграции.'],
	['Можно ли\u00A0интегрировать РосБизнесСофт с\u00A01С?', 'Да. Настраиваем обмен по\u00A0клиентам, товарам, счетам, заказам, оплатам, остаткам и\u00A0другим данным. Состав обмена зависит от\u00A0конфигурации 1С\u00A0и\u00A0ваших процессов.'],
	['Можно ли\u00A0перенести данные из\u00A0Excel или\u00A0старой CRM?', 'Да. Переносим клиентов, компании, контакты, сделки, товары, остатки и\u00A0другую информацию из\u00A0Excel, 1С, старой CRM\u00A0или\u00A0внешних систем.'],
	['Сколько времени занимает внедрение?', 'Быстрый запуск выполняется в\u00A0рамках первичного внедрения это от\u00A0недели. Проектное внедрение обычно идет этапами: обследование, ТЗ, настройка, интеграции, перенос данных, обучение и\u00A0запуск. Проектное внедрение может занять от\u00A02\u00A0до\u00A06\u00A0месяцев.'],
	['Подходит ли\u00A0РосБизнесСофт для\u00A0производства?', 'Да. Система подходит компаниям, которым нужно связать продажи, производство, склад, закупки, документы и\u00A0отгрузки.'],
	['Подходит ли\u00A0РосБизнесСофт для\u00A0сервисного центра?', 'Да. Есть тариф service desk: обращения, тикеты, сервисные заявки, оборудование клиентов, задачи инженеров.'],
	['Можно ли\u00A0подключить сайт к\u00A0РосБизнесСофт?', 'Да. Заявки с\u00A0сайта можно передавать в\u00A0CRM, создавать лиды, сделки, задачи и\u00A0уведомления для\u00A0менеджеров.'],
	['Что входит в\u00A0первичное внедрение?', 'Базовая настройка CRM, структура компании, пользователи, роли, поля, воронка, шаблоны документов, почта, телефония, доступные интеграции и\u00A0обучение по\u00A0базовому сценарию.'],
	['Что лучше: РосБизнесСофт или\u00A0Битрикс24?', 'Если нужна простая CRM\u00A0для\u00A0продаж, задач и\u00A0коммуникаций, часто рассматривают Bitrix24. Если важны склад, производство, сервис, закупки, документы и\u00A0глубокая ERP-логика, стоит рассмотреть РосБизнесСофт.'],
] as const;

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Внедрение CRM\u00A0/\u00A0ERP\u00A0системы РосБизнесСофт',
		provider: {
			'@type': 'Organization',
			name: 'IT\u00A0TIME\u00A0NOW',
		},
		areaServed: 'RU',
		serviceType: 'CRM/ERP implementation',
		description:
			'Внедрение и\u00A0настройка CRM/ERP\u00A0системы РосБизнесСофт для\u00A0продаж, склада, производства, сервиса и\u00A0B2B.',
		offers: {
			'@type': 'AggregateOffer',
			priceCurrency: 'RUB',
			lowPrice: '80000',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(([question, answer]) => ({
			'@type': 'Question',
			name: question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: answer,
			},
		})),
	},
];
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<div class="ds2 rbs-ds2">
	<section class="ds2-hero rbs-hero">
		<div class="ds2-container rbs-hero-grid">
			<div>
				<nav class="rbs-breadcrumbs" aria-label="Хлебные крошки">
					<a href="/services">Все услуги</a>
					<UiIcon name="chevron" class="h-3.5 w-3.5" />
					<span>РосБизнесСофт CRM&nbsp;/&nbsp;ERP</span>
				</nav>
				<h1 transition:name="service-rbs">Внедрение CRM&nbsp;/&nbsp;ERP&nbsp;системы РосБизнесСофт</h1>
				<p class="rbs-lead">
					Внедрим РосБизнесСофт под&nbsp;ваши продажи, склад, производство и&nbsp;сервис. Поможем перейти
					от&nbsp;Excel, разрозненных таблиц и&nbsp;ручного контроля к&nbsp;единой CRM/ERP&nbsp;системе, где виден
					весь путь клиента: от&nbsp;первого обращения и&nbsp;сделки до&nbsp;счета, отгрузки, сервиса и&nbsp;повторной продажи.
				</p>
				<div class="rbs-actions">
					<a class="ds2-btn ds2-btn-primary" href="#rbs-request">
						<span>Получить консультацию</span>
						<UiIcon name="arrow" class="h-4 w-4" />
					</a>
					<p class="rbs-free-label">Бесплатно!</p>
				</div>
				<div class="ds2-testimonial rbs-hero-benefit">
					<div class="rbs-hero-benefit-head">
						<UiIcon name="thumbs-up" class="rbs-hero-benefit-icon h-[52px] w-[52px] shrink-0 text-white/90" />
						<p class="ds2-kicker">Ваша выгода</p>
					</div>
					<blockquote>
						После внедрения РосБизнесСофт компания получает единую систему для&nbsp;продаж,
						операций и&nbsp;управленческого контроля.
					</blockquote>
					<ul>
						{heroBenefits.map((item) => (
							<li>
								<UiIcon name="check" class="h-4 w-4" />
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<picture class="rbs-hero-media">
				<img
					src="/main-rbs.png"
					alt="Интерфейс РосБизнесСофт с&nbsp;CRM, ERP-модулями и&nbsp;операционными данными"
					width="1086"
					height="1448"
					loading="eager"
					decoding="async"
				/>
			</picture>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
			<div class="ds2-section-head rbs-wide-head">
				<div>
					<p class="ds2-kicker">Кому подойдет</p>
					<h2>Когда простой CRM&nbsp;уже недостаточно</h2>
				</div>
				<p>
					РосБизнесСофт&nbsp;/&nbsp;RBS360 подходит компаниям, где&nbsp;CRM&nbsp;должна быть связана с&nbsp;реальными
					операциями: продажами, складом, производством, сервисом, закупками и&nbsp;документами.
				</p>
			</div>
			<div class="rbs-fit-grid">
				{fitItems.map((item) => (
					<article class="ds2-service-card rbs-fit-card">
						<UiIcon name="check" class="h-5 w-5" />
						<p>{item}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section ds2-section-soft">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Задачи внедрения</p>
					<h2>Настраиваем систему под&nbsp;работу отделов, а&nbsp;не&nbsp;отдельную CRM-карточку</h2>
				</div>
				<p>
					IT&nbsp;TIME&nbsp;NOW внедряет РосБизнесСофт под&nbsp;реальные бизнес-процессы: структуру компании,
					права доступа, карточки, воронки, документы, интеграции, отчеты и&nbsp;регламенты.
				</p>
			</div>
			<div class="rbs-task-grid">
				{tasks.map(({ icon, title, text }) => (
					<article class="ds2-service-card rbs-task-card">
						<div class="ds2-service-icon">
							<UiIcon name={icon} class="h-5 w-5" />
						</div>
						<h3>{title}</h3>
						<p>{text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container rbs-benefit-layout">
			<div>
				<p class="ds2-kicker">Ваша выгода</p>
				<h2>Единый процесс от&nbsp;заявки до&nbsp;повторной продажи</h2>
				<p>
					Мы не&nbsp;просто включаем CRM. Цель внедрения - сделать так, чтобы менеджеры, склад,
					производство, сервис и&nbsp;руководство работали в&nbsp;одной системе.
				</p>
			</div>
			<div class="rbs-benefits">
				{benefits.map(([title, text]) => (
					<article class="ds2-card rbs-benefit-card">
						<UiIcon name="check" class="h-5 w-5" />
						<h3>{title}</h3>
						<p>{text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section id="rbs-prices" class="ds2-section ds2-section-soft">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Стоимость внедрения</p>
					<h2>Пакеты внедрения РосБизнесСофт</h2>
				</div>
				<p>
					Итоговая стоимость зависит от&nbsp;количества пользователей, модулей, интеграций, объема
					данных для&nbsp;переноса и&nbsp;сложности бизнес-процессов.
				</p>
			</div>
			<div class="rbs-prices">
				{packages.map((pack) => (
					<article class:list={['ds2-price-card', pack.featured && 'is-featured']}>
						<div class="rbs-card-top">
							<div class="ds2-service-icon">
								<UiIcon name={pack.icon} class="h-5 w-5" />
							</div>
