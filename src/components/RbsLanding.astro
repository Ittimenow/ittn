---
import UiIcon from './UiIcon.astro';

const heroBenefits = [
	'единая база клиентов и сделок',
	'продажи связаны со складом',
	'меньше ручного контроля',
	'документы по шаблонам',
	'интеграции с 1С и сайтом',
	'понятные KPI и отчеты',
] as const;

const fitItems = [
	'B2B-продажи с долгим циклом сделки',
	'оптовая или дистрибьюторская компания',
	'производство с заказами, материалами и отгрузками',
	'складской учет, закупки и остатки',
	'сервисный центр или выездные инженеры',
	'строительная, проектная или монтажная компания',
	'несколько отделов с потерями задач и документов',
	'1С, сайт, телефония и почта, которые нужно связать',
] as const;

const tasks = [
	{
		icon: 'briefcase',
		title: 'Наводим порядок в продажах',
		text: 'Настраиваем клиентскую базу, сделки, воронки, задачи, напоминания, контроль звонков и писем.',
	},
	{
		icon: 'workflow',
		title: 'Связываем CRM и ERP-логику',
		text: 'Соединяем заказы клиентов, номенклатуру, остатки, закупки, производство, отгрузки и документы.',
	},
	{
		icon: 'layers',
		title: 'Настраиваем интеграции',
		text: 'Подключаем сайт, формы, почту, телефонию, мессенджеры, 1С, API и внешние сервисы.',
	},
	{
		icon: 'database',
		title: 'Переносим данные',
		text: 'Мигрируем клиентов, компании, контакты, товары, сделки, историю и остатки из Excel, 1С или старой CRM.',
	},
	{
		icon: 'file',
		title: 'Автоматизируем документы',
		text: 'Создаем шаблоны КП, договоров, счетов, актов, УПД и писем, чтобы сотрудники не копировали данные вручную.',
	},
	{
		icon: 'users',
		title: 'Внедряем в ежедневную работу',
		text: 'Обучаем команду, готовим инструкции, регламенты, KPI и правила контроля качества заполнения CRM.',
	},
] as const;

const benefits = [
	['Единая система', 'Клиенты, сделки, задачи, документы, склад, производство и сервис работают в одном пространстве.'],
	['Меньше ручной работы', 'Заявки попадают в CRM, письма и звонки привязываются к клиенту, документы формируются по шаблонам.'],
	['Контроль продаж', 'Руководитель видит воронки, этапы сделок, просрочки, активность менеджеров и прогноз продаж.'],
	['Быстрее обработка заказов', 'Менеджеры, склад и производство работают по единому процессу, без передачи данных в чатах и Excel.'],
	['Меньше ошибок', 'Регламенты, поля, роли и автоматизация снижают риск забытых задач и неверных данных в заказах.'],
	['Рост вместе с бизнесом', 'РосБизнесСофт можно дорабатывать под отрасль, подразделения, роли, отчеты и нестандартные процессы.'],
] as const;

const packages = [
	{
		name: 'Предпроектное обследование',
		price: 'от 50 000 ₽',
		icon: 'filter',
		tag: 'План',
		text: 'Когда нужно описать процессы, выбрать модули и получить понятную дорожную карту внедрения.',
		items: ['интервью с руководителями', 'карта процессов и проблем', 'состав модулей и интеграций', 'план работ и смета'],
	},
	{
		name: 'Первичное внедрение',
		price: '80 000 ₽',
		icon: 'rocket',
		tag: 'Старт',
		text: 'Быстрый запуск CRM с базовой настройкой для продаж, пользователей, прав и рабочего сценария.',
		items: ['структура компании', 'пользователи, роли и права', 'карточки и воронки', 'базовое обучение'],
	},
	{
		name: 'Проектное внедрение',
		price: 'от 300 000 ₽',
		icon: 'workflow',
		tag: 'Комплексно',
		featured: true,
		text: 'Настройка под процессы компании: CRM, ERP-модули, интеграции, перенос данных, обучение и адаптация.',
		items: ['аудит и ТЗ', 'CRM и ERP-модули', '1С, сайт, телефония и API', 'миграция, запуск и сопровождение'],
	},
] as const;

const extraPrices = [
	['Настройка CRM', 'Поля, карточки, воронки, пользователи, права, рабочий стол', 'от 25 000 ₽'],
	['Интеграция с 1С', 'Аудит 1С, правила обмена, синхронизация документов и данных', 'от 30 000 ₽'],
	['Интеграция сайта с CRM', 'Передача заявок с сайта в РосБизнесСофт', 'от 5 000 ₽'],
	['Телефония', 'Подключение АТС и правил обработки звонков', 'от 5 000 ₽'],
	['Email', 'Подключение почты сотрудников к CRM', '500 ₽ / сотрудник'],
	['Шаблоны документов', 'КП, договор, счет, письмо, акт, УПД', 'от 1 000 ₽ / документ'],
	['Обучение сотрудников', 'Работа с CRM, складом, сделками и клиентской базой', 'от 10 000 ₽'],
	['Регламент работы в CRM', 'Правила обработки заявок, сделок, клиентов и задач', 'от 10 000 ₽'],
] as const;

const services = [
	{
		title: 'Предпроектное обследование',
		icon: 'filter',
		items: ['интервью с руководителями и ключевыми сотрудниками', 'описание текущих процессов', 'карта внедрения и список настроек'],
	},
	{
		title: 'Настройка CRM и ERP-модулей',
		icon: 'settings',
		items: ['карточки клиентов, сделок, заказов и товаров', 'склады, документы, проекты и сервисные обращения', 'производственные процессы'],
	},
	{
		title: 'Интеграция с 1С',
		icon: 'database',
		items: ['контрагенты, товары и счета', 'заказы, оплаты и остатки', 'правила обмена под вашу конфигурацию'],
	},
	{
		title: 'Интеграции с каналами',
		icon: 'phone',
		items: ['заявки с сайта и лендингов', 'телефония, почта и мессенджеры', 'API и внешние сервисы'],
	},
	{
		title: 'Миграция данных',
		icon: 'layers',
		items: ['клиенты, контакты и компании', 'сделки, товары и остатки', 'документы и история взаимодействий'],
	},
	{
		title: 'Отчеты, обучение и поддержка',
		icon: 'bar-chart',
		items: ['отчеты по продажам, складу, сервису и KPI', 'инструкции и обучение пользователей', 'помощь после запуска'],
	},
] as const;

const steps = [
	['filter', 'Аудит', 'Фиксируем цели, процессы, роли, данные и точки потерь.'],
	['file', 'Техническое задание', 'Описываем модули, карточки, поля, документы, интеграции и критерии готовности.'],
	['settings', 'Настройка', 'Конфигурируем CRM/ERP, права, воронки, рабочие столы, документы и отчеты.'],
	['layers', 'Интеграции', 'Связываем РосБизнесСофт с 1С, сайтом, телефонией, почтой, API и внешними сервисами.'],
	['database', 'Перенос данных', 'Импортируем и проверяем клиентов, товары, сделки, остатки, документы и историю.'],
	['users', 'Обучение', 'Показываем сотрудникам рабочие сценарии и закрепляем регламенты.'],
	['rocket', 'Запуск и развитие', 'Запускаем систему, контролируем первые результаты и донастраиваем процессы.'],
] as const;

const clients = [
	{ name: 'Perola Sky', src: '/clients/client-perola.png' },
	{ name: 'William Grant & Sons Ltd.', src: '/clients/client-wgs.png' },
	{ name: 'Альфа-страхование', src: '/clients/client-alfa.png' },
	{ name: 'Донстрой', src: '/clients/client-donstroy.png' },
] as const;

const trustItems = [
	'работаем с CRM/ERP, автоматизацией и интеграциями',
	'настраиваем систему под реальные процессы, а не только по инструкции',
	'подключаем 1С, сайт, телефонию, почту и внешние сервисы',
	'готовим регламенты и обучающие материалы для сотрудников',
	'работаем по договору, с этапами, сметой и понятным результатом',
] as const;

const outcomes = [
	['Стало понятно, где сделки', 'После настройки воронок, задач и отчетов руководитель видит загрузку, просрочки и прогноз продаж.'],
	['Документы готовятся быстрее', 'Шаблоны счетов, договоров и КП уменьшают ручной ввод и количество ошибок.'],
	['Заявки не теряются', 'Формы сайта, почта и телефония связаны с CRM, поэтому каждое обращение попадает в работу.'],
] as const;

const faqs = [
	['Сколько стоит внедрение РосБизнесСофт?', 'Быстрое внедрение в IT TIME NOW стоит от 80 000 ₽. Проектное внедрение - от 300 000 ₽. Итог зависит от количества пользователей, модулей, интеграций, объема данных и сложности процессов.'],
	['Чем РосБизнесСофт отличается от обычной CRM?', 'Обычная CRM чаще закрывает продажи, задачи и клиентскую базу. РосБизнесСофт может работать как CRM/ERP-система: продажи, склад, закупки, производство, сервис, документы, отчеты и интеграции.'],
	['Можно ли интегрировать РосБизнесСофт с 1С?', 'Да. Настраиваем обмен по клиентам, товарам, счетам, заказам, оплатам, остаткам и другим данным. Состав обмена зависит от конфигурации 1С и ваших процессов.'],
	['Можно ли перенести данные из Excel или старой CRM?', 'Да. Переносим клиентов, компании, контакты, сделки, товары, остатки и другую информацию из Excel, 1С, старой CRM или внешних систем.'],
	['Сколько времени занимает внедрение?', 'Быстрый запуск выполняется в рамках первичного внедрения. Проектное внедрение обычно идет этапами: обследование, ТЗ, настройка, интеграции, перенос данных, обучение и запуск.'],
	['Подходит ли РосБизнесСофт для производства?', 'Да. Система подходит компаниям, которым нужно связать продажи, производство, склад, закупки, документы и отгрузки.'],
	['Подходит ли РосБизнесСофт для сервисного центра?', 'Да. Можно настроить обращения, тикеты, сервисные заявки, оборудование клиентов, задачи инженеров и отчеты.'],
	['Можно ли подключить сайт к РосБизнесСофт?', 'Да. Заявки с сайта можно передавать в CRM, создавать лиды, сделки, задачи и уведомления для менеджеров.'],
	['Что входит в первичное внедрение?', 'Базовая настройка CRM, структура компании, пользователи, роли, поля, воронка, шаблоны документов, почта, телефония, доступные интеграции и обучение по базовому сценарию.'],
	['Что лучше: РосБизнесСофт или Битрикс24?', 'Если нужна простая CRM для продаж, задач и коммуникаций, часто рассматривают Bitrix24. Если важны склад, производство, сервис, закупки, документы и глубокая ERP-логика, стоит рассмотреть РосБизнесСофт.'],
] as const;

const schema = [
	{
		'@context': 'https://schema.org',
		'@type': 'Service',
		name: 'Внедрение CRM / ERP системы РосБизнесСофт',
		provider: {
			'@type': 'Organization',
			name: 'IT TIME NOW',
		},
		areaServed: 'RU',
		serviceType: 'CRM/ERP implementation',
		description:
			'Внедрение и настройка CRM/ERP системы РосБизнесСофт для продаж, склада, производства, сервиса и B2B.',
		offers: {
			'@type': 'AggregateOffer',
			priceCurrency: 'RUB',
			lowPrice: '80000',
		},
	},
	{
		'@context': 'https://schema.org',
		'@type': 'FAQPage',
		mainEntity: faqs.map(([question, answer]) => ({
			'@type': 'Question',
			name: question,
			acceptedAnswer: {
				'@type': 'Answer',
				text: answer,
			},
		})),
	},
];
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

<div class="ds2 rbs-ds2">
	<section class="ds2-hero rbs-hero">
		<div class="ds2-container rbs-hero-grid">
			<div>
				<nav class="rbs-breadcrumbs" aria-label="Хлебные крошки">
					<a href="/services">Все услуги</a>
					<UiIcon name="chevron" class="h-3.5 w-3.5" />
					<span>РосБизнесСофт CRM / ERP</span>
				</nav>
				<h1 transition:name="service-rbs">Внедрение CRM / ERP системы РосБизнесСофт</h1>
				<p class="rbs-lead">
					Внедрим РосБизнесСофт под ваши продажи, склад, производство и сервис. Поможем перейти
					от Excel, разрозненных таблиц и ручного контроля к единой CRM/ERP системе, где виден
					весь путь клиента: от первого обращения и сделки до счета, отгрузки, сервиса и
					повторной продажи.
				</p>
				<div class="rbs-actions">
					<a class="ds2-btn ds2-btn-primary" href="#rbs-request">
						<span>Получить консультацию</span>
						<UiIcon name="arrow" class="h-4 w-4" />
					</a>
					<a class="ds2-btn ds2-btn-secondary" href="#rbs-prices">
						<span>Рассчитать внедрение</span>
						<UiIcon name="file" class="h-4 w-4" />
					</a>
				</div>
				<div class="ds2-testimonial rbs-hero-benefit">
					<div class="rbs-hero-benefit-head">
						<UiIcon name="thumbs-up" class="rbs-hero-benefit-icon h-[52px] w-[52px] shrink-0 text-white/90" />
						<p class="ds2-kicker">Ваша выгода</p>
					</div>
					<blockquote>
						После внедрения РосБизнесСофт компания получает единую систему для продаж,
						операций и управленческого контроля.
					</blockquote>
					<ul>
						{heroBenefits.map((item) => (
							<li>
								<UiIcon name="check" class="h-4 w-4" />
								<span>{item}</span>
							</li>
						))}
					</ul>
				</div>
			</div>

			<picture class="rbs-hero-media">
				<img
					src="/main-rbs.png"
					alt="Интерфейс РосБизнесСофт с CRM, ERP-модулями и операционными данными"
					width="1086"
					height="1448"
					loading="eager"
					decoding="async"
				/>
			</picture>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container">
			<div class="ds2-section-head rbs-wide-head">
				<div>
					<p class="ds2-kicker">Кому подойдет</p>
					<h2>Когда простой CRM уже недостаточно</h2>
				</div>
				<p>
					РосБизнесСофт / RBS360 подходит компаниям, где CRM должна быть связана с реальными
					операциями: продажами, складом, производством, сервисом, закупками и документами.
				</p>
			</div>
			<div class="rbs-fit-grid">
				{fitItems.map((item) => (
					<article class="ds2-service-card rbs-fit-card">
						<UiIcon name="check" class="h-5 w-5" />
						<p>{item}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section ds2-section-soft">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Задачи внедрения</p>
					<h2>Настраиваем систему под работу отделов, а не отдельную CRM-карточку</h2>
				</div>
				<p>
					IT TIME NOW внедряет РосБизнесСофт под реальные бизнес-процессы: структуру компании,
					права доступа, карточки, воронки, документы, интеграции, отчеты и регламенты.
				</p>
			</div>
			<div class="rbs-task-grid">
				{tasks.map(({ icon, title, text }) => (
					<article class="ds2-service-card rbs-task-card">
						<div class="ds2-service-icon">
							<UiIcon name={icon} class="h-5 w-5" />
						</div>
						<h3>{title}</h3>
						<p>{text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section class="ds2-section">
		<div class="ds2-container rbs-benefit-layout">
			<div>
				<p class="ds2-kicker">Ваша выгода</p>
				<h2>Единый процесс от заявки до повторной продажи</h2>
				<p>
					Мы не просто включаем CRM. Цель внедрения - сделать так, чтобы менеджеры, склад,
					производство, сервис и руководство работали в одной системе.
				</p>
			</div>
			<div class="rbs-benefits">
				{benefits.map(([title, text]) => (
					<article class="ds2-card rbs-benefit-card">
						<UiIcon name="check" class="h-5 w-5" />
						<h3>{title}</h3>
						<p>{text}</p>
					</article>
				))}
			</div>
		</div>
	</section>

	<section id="rbs-prices" class="ds2-section ds2-section-soft">
		<div class="ds2-container">
			<div class="ds2-section-head">
				<div>
					<p class="ds2-kicker">Стоимость внедрения</p>
					<h2>Пакеты IT TIME NOW для РосБизнесСофт</h2>
				</div>
				<p>
					Итоговая стоимость зависит от количества пользователей, модулей, интеграций, объема
					данных для переноса и сложности бизнес-процессов.
				</p>
			</div>
			<div class="rbs-prices">
				{packages.map((pack) => (
					<article class:list={['ds2-price-card', pack.featured && 'is-featured']}>
						<div class="rbs-card-top">
							<div class="ds2-service-icon">
								<UiIcon name={pack.icon} class="h-5 w-5" />
							</div>
							<span class="ds2-chip">{pack.tag}</span>
						</div>
						<h3>{pack.name}</h3>
						<p class="rbs-price">{pack.price}</p>
						<p class="rbs-card-text">{pack.text}</p>
						<ul>
							{pack.items.map((item) => (
								<li>
									<UiIcon name="check" class="h-4 w-4" />
									<span>{item}</span>
								</li>
							))}
						</ul>
						<a class="ds2-btn ds2-btn-secondary" href="#rbs-request">
							<span>Обсудить состав</span>
						</a>
					</article>
				))}
			</div>
			<section class="ds2-card rbs-price-table-card" aria-label="Отдельные работы по внедрению РосБизнесСофт">
				<div class="rbs-table-head">
					<div>
						<p class="ds2-kicker">Отдельные работы</p>
						<h3>Можно собрать внедрение по модулям</h3>
					</div>
					<p>После короткого интервью подготовим план работ и понятную смету.</p>
				</div>
				<div class="rbs-table-wrap">
					<table class="ds2-table">
						<thead>
